---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  toolName: string;
  toolVersion?: string;
  status?: 'ready' | 'running' | 'complete' | 'error';
}

const {
  title,
  description = '',
  toolName,
  toolVersion = '1.0.0',
  status = 'ready',
} = Astro.props;

const statusColors: Record<string, string> = {
  ready: 'text-terminal-cyan',
  running: 'text-terminal-amber',
  complete: 'text-terminal-green',
  error: 'text-terminal-red',
};

const statusLabels: Record<string, string> = {
  ready: 'READY',
  running: 'RUNNING...',
  complete: 'COMPLETE',
  error: 'ERROR',
};
---

<BaseLayout
  title={title}
  description={description}
  statusLeft={`tool: ${toolName}`}
  statusRight={`v${toolVersion}`}
>
  <!-- Tool header -->
  <div class="flex items-center justify-between flex-wrap gap-2 mb-3">
    <div class="text-terminal-green text-glow-green font-bold">
      ~/tools/<span class="text-white">{toolName}</span>
    </div>
    <div class="flex items-center gap-2 text-xs">
      <span class="flex items-center gap-1.5">
        <span class={`inline-block w-2 h-2 ${status === 'running' ? 'animate-pulse' : ''} ${status === 'ready' ? 'bg-terminal-cyan' : status === 'running' ? 'bg-terminal-amber' : status === 'complete' ? 'bg-terminal-green' : 'bg-terminal-red'}`}></span>
        <span class={statusColors[status]} id="tool-status-label">{statusLabels[status]}</span>
      </span>
    </div>
  </div>

  {description && (
    <div class="text-terminal-muted text-xs mb-3">{description}</div>
  )}

  <hr class="tui-hr" />

  <!-- Tool output log -->
  <div class="tui-box p-3 mb-3 max-h-[250px] overflow-y-auto" id="tool-output">
    <span class="tui-box-title text-terminal-muted">┤ OUTPUT ├</span>
    <div id="tool-log" class="space-y-0.5 text-xs mt-1">
      <div class="text-terminal-muted"><span class="text-terminal-green">[INIT]</span> {toolName} v{toolVersion} loaded</div>
      <div class="text-terminal-muted"><span class="text-terminal-cyan">[INFO]</span> All processing runs in your browser</div>
      <div class="text-terminal-muted"><span class="text-terminal-cyan">[INFO]</span> No data is transmitted to any server</div>
    </div>
  </div>

  <!-- Controls area -->
  <div class="mb-3" id="tool-controls">
    <slot name="controls" />
  </div>

  <!-- Results area -->
  <div class="mb-3" id="tool-results">
    <slot name="results" />
  </div>

  <!-- Additional content -->
  <div id="tool-extra">
    <slot />
  </div>
</BaseLayout>

<style>
  #tool-output { scroll-behavior: smooth; }
  #tool-log > div { animation: fadeIn 0.15s ease-in; }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(2px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  function appendLog(message: string, level: 'info' | 'warn' | 'error' | 'success' = 'info') {
    const log = document.getElementById('tool-log');
    if (!log) return;
    const colors: Record<string, string> = { info: 'text-terminal-cyan', warn: 'text-terminal-amber', error: 'text-terminal-red', success: 'text-terminal-green' };
    const labels: Record<string, string> = { info: 'INFO', warn: 'WARN', error: 'ERROR', success: 'DONE' };
    const div = document.createElement('div');
    div.className = 'text-terminal-muted';
    div.innerHTML = `<span class="${colors[level]}">[${labels[level]}]</span> ${message}`;
    log.appendChild(div);
    const output = document.getElementById('tool-output');
    if (output) output.scrollTop = output.scrollHeight;
  }

  function setToolStatus(status: 'ready' | 'running' | 'complete' | 'error') {
    const label = document.getElementById('tool-status-label');
    if (!label) return;
    const colors: Record<string, string> = { ready: 'text-terminal-cyan', running: 'text-terminal-amber', complete: 'text-terminal-green', error: 'text-terminal-red' };
    const labels: Record<string, string> = { ready: 'READY', running: 'RUNNING...', complete: 'COMPLETE', error: 'ERROR' };
    label.className = colors[status];
    label.textContent = labels[status];
  }

  (window as any).privacyTerminal = { appendLog, setToolStatus };
</script>
