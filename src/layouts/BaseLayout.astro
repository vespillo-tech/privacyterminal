---
import { getCollection, getEntry } from 'astro:content';
import '../styles/global.css';
import PrivacyScore from '../components/PrivacyScore.astro';
import AuthModal from '../components/AuthModal.astro';
import AchievementToast from '../components/AchievementToast.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  statusLeft?: string;
  statusRight?: string;
}

const {
  title = 'Privacy Terminal',
  description = 'Open-source privacy tools and education. Test your browser fingerprint, detect leaks, and learn to protect your digital identity.',
  ogImage = '/og-default.png',
  statusLeft = 'system ready',
  statusRight = '',
} = Astro.props;

// ── Load singletons from content collections ──────────────────
const navEntry     = await getEntry('site', 'navigation');
const settingsEntry = await getEntry('site', 'site-settings');
const gameEntry    = await getEntry('site', 'game-config');

const navData = navEntry?.data as {
  items: Array<{ label: string; href: string; key: string }>;
};

const settings = settingsEntry?.data as {
  site_name: string;
  version: string;
  site_url: string;
  security_txt: string;
};

const gameConfig = gameEntry?.data as {
  levels: Array<{ level: number; name: string; min: number; max: number }>;
  guide_points: number;
  tool_points: number;
  api_base: string;
};

// ── Build achievements map for client-side injection ──────────
const achievementEntries = await getCollection('achievements');
const achievementsMap: Record<string, unknown> = {};
for (const entry of achievementEntries) {
  achievementsMap[entry.data.id] = {
    id:          entry.data.id,
    name:        entry.data.name,
    icon:        entry.data.icon,
    description: entry.data.description,
    points:      entry.data.points,
  };
}

// JSON payload injected into <head> for client-side privacy-score.ts
const gameDataJson = JSON.stringify({
  achievements: achievementsMap,
  levels:       gameConfig?.levels       ?? [],
  guidePoints:  gameConfig?.guide_points ?? 15,
  toolPoints:   gameConfig?.tool_points  ?? 10,
  apiBase:      gameConfig?.api_base     ?? 'https://privacyterminal-api.workers.dev',
});

const navItems = navData?.items ?? [
  { label: 'home',     href: '/',        key: '0' },
  { label: 'tools',    href: '/tools',    key: '1' },
  { label: 'guides',   href: '/guides',   key: '2' },
  { label: 'terminal', href: '/terminal', key: '3' },
  { label: 'about',    href: '/about',    key: '4' },
];

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={settings?.site_name ?? 'Privacy Terminal'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/JetBrainsMono-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/JetBrainsMono-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <!-- Game config + achievements injected at build time for client-side scripts -->
    <script type="application/json" id="pt-game-data" set:html={gameDataJson} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": settings?.site_name ?? "Privacy Terminal",
      "url": settings?.site_url ?? "https://privacyterminal.com",
      "description": "Open-source privacy tools and education. All tools run client-side.",
      "publisher": {
        "@type": "Organization",
        "name": settings?.site_name ?? "Privacy Terminal",
        "url": settings?.site_url ?? "https://privacyterminal.com"
      }
    })} />
  </head>
  <body class="bg-terminal-bg min-h-screen font-mono text-sm antialiased flex flex-col">
    <!-- Scanline overlay -->
    <div class="scanlines" aria-hidden="true"></div>

    <!-- TOP STATUS BAR -->
    <header class="tui-topbar">
      <div class="flex items-center justify-between w-full px-2 md:px-4">
        <div class="flex items-center gap-1">
          <span class="text-terminal-green font-bold">&#9656; PRIVACY TERMINAL</span>
          <span class="text-terminal-muted text-xs hidden sm:inline">{settings?.version ?? 'v0.1.0'}</span>
        </div>
        <nav class="flex items-center gap-0">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'tui-tab',
                isActive(item.href) ? 'tui-tab-active' : '',
              ]}
            >
              <span class="text-terminal-muted">{item.key}:</span>{item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="flex-1 overflow-y-auto px-2 md:px-4 py-3">
      <slot />
    </main>

    <!-- BOTTOM STATUS BAR -->
    <footer class="tui-bottombar">
      <div class="flex items-center justify-between w-full px-2 md:px-4">
        <span>
          <span class="text-terminal-green">&#9679;</span>
          <span class="text-terminal-muted ml-1">{statusLeft}</span>
        </span>
        <span class="flex items-center gap-3">
          {statusRight && <span class="text-terminal-muted">{statusRight}</span>}
          <PrivacyScore />
          <span class="text-terminal-muted hidden sm:inline">&#124;</span>
          <span class="text-terminal-muted hidden sm:inline">no tracking</span>
          <span class="text-terminal-muted hidden sm:inline">&#124;</span>
          <span class="text-terminal-muted hidden sm:inline">no cookies</span>
          <span class="text-terminal-muted hidden sm:inline">&#124;</span>
          <a href={settings?.security_txt ?? '/.well-known/security.txt'} class="text-terminal-muted hover:text-terminal-cyan hidden sm:inline">security.txt</a>
        </span>
      </div>
    </footer>

    <AuthModal />
    <AchievementToast />

    <script>
      import { initPrivacyScore } from '../scripts/privacy-score';
      initPrivacyScore();
    </script>
  </body>
</html>
