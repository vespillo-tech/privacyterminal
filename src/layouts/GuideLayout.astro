---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  category?: string;
  readingTime?: string;
  publishedDate?: string;
  updatedDate?: string;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  tldr?: string[];
  difficulty?: number;
}

const {
  title,
  description = '',
  category = 'guide',
  readingTime = '',
  publishedDate = '',
  updatedDate = '',
  headings = [],
  tldr = [],
  difficulty = 1,
} = Astro.props;

function difficultyBar(d: number): string {
  return '█'.repeat(d) + '░'.repeat(5 - d);
}
const difficultyLabels = ['', 'Beginner', 'Easy', 'Intermediate', 'Advanced', 'Expert'];

const categoryColors: Record<string, string> = {
  foundations: 'text-terminal-green',
  essentials: 'text-terminal-cyan',
  intermediate: 'text-terminal-amber',
  advanced: 'text-terminal-red',
  guide: 'text-terminal-muted',
};
---

<BaseLayout
  title={`${title} — Privacy Terminal`}
  description={description}
  statusLeft={`guide: ${category}`}
  statusRight={readingTime || ''}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": publishedDate || undefined,
    "dateModified": updatedDate || publishedDate || undefined,
    "publisher": {
      "@type": "Organization",
      "name": "Privacy Terminal",
      "url": "https://privacyterminal.com"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://privacyterminal.com${Astro.url.pathname}`
    }
  })} />
  <div class="flex flex-col lg:flex-row gap-4">
    <!-- Sidebar / Table of Contents -->
    <aside class="lg:w-48 shrink-0 order-2 lg:order-1">
      <div class="lg:sticky lg:top-10">
        <!-- Guide metadata -->
        <div class="tui-box p-3 mb-0">
          <span class="tui-box-title text-terminal-muted">┤ META ├</span>
          <div class="text-[10px] space-y-1 mt-1">
            <div><span class="text-terminal-muted">cat:</span> <span class={categoryColors[category] || 'text-terminal-muted'}>{category}</span></div>
            {readingTime && <div><span class="text-terminal-muted">time:</span> <span class="text-gray-400">{readingTime}</span></div>}
            {publishedDate && <div><span class="text-terminal-muted">pub:</span> <span class="text-gray-400">{publishedDate}</span></div>}
            {updatedDate && <div><span class="text-terminal-muted">upd:</span> <span class="text-gray-400">{updatedDate}</span></div>}
          </div>
        </div>

        <!-- Table of Contents -->
        {headings.length > 0 && (
          <div class="tui-box p-3">
            <span class="tui-box-title text-terminal-amber">┤ TOC ├</span>
            <nav class="text-[10px] mt-1" aria-label="Table of contents">
              <ul class="space-y-0.5">
                {headings
                  .filter((h) => h.depth <= 3)
                  .map((heading) => (
                    <li class:list={[heading.depth === 3 ? 'pl-2' : '']}>
                      <a
                        href={`#${heading.slug}`}
                        class="text-terminal-muted hover:text-terminal-cyan transition-colors block py-0.5 no-underline truncate"
                        data-toc-link
                      >
                        <span class="text-terminal-green mr-1">{heading.depth === 2 ? '├─' : '│└'}</span>{heading.text}
                      </a>
                    </li>
                  ))}
              </ul>
            </nav>
          </div>
        )}

        <!-- Back -->
        <div class="py-2 px-3">
          <a href="/guides" class="text-xs text-terminal-muted hover:text-terminal-cyan no-underline">← cd ../guides</a>
        </div>
      </div>
    </aside>

    <!-- Main content -->
    <article class="flex-1 order-1 lg:order-2 min-w-0">
      <!-- Guide header -->
      <header class="mb-4">
        <div class="text-xs text-terminal-muted mb-1">
          <a href="/guides" class="hover:text-terminal-cyan no-underline">~/guides</a>/<span class={categoryColors[category] || 'text-terminal-muted'}>{category}</span>/
        </div>
        <h1 class="text-terminal-green text-glow-green text-lg font-bold leading-tight mb-2">{title}</h1>
        {description && <p class="text-terminal-muted text-xs">{description}</p>}
        {difficulty > 0 && (
          <div class="mt-2 text-xs">
            <span class="text-terminal-muted">DIFFICULTY: </span>
            <span class="text-terminal-green">{difficultyBar(difficulty)}</span>
            <span class="text-terminal-muted"> ({difficulty}/5 {difficultyLabels[difficulty]})</span>
          </div>
        )}
      {tldr.length > 0 && (
        <div class="tui-box p-3 mb-2">
          <span class="tui-box-title text-terminal-green">┤ TL;DR ├</span>
          <ul class="mt-1 space-y-1">
            {tldr.map((point) => (
              <li class="text-terminal-muted text-xs flex gap-2">
                <span class="text-terminal-green shrink-0">▸</span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <hr class="tui-hr" />

      <!-- Guide body — readable width like a man page -->
      <div class="guide-content max-w-[70ch]">
        <slot />
      </div>

      <!-- Guide Completion -->
      <div class="mt-8 border-t border-terminal-border pt-4" id="guide-completion">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span id="completion-icon" class="text-terminal-muted">☐</span>
            <span id="completion-text" class="text-terminal-muted text-xs">Mark this guide as read</span>
          </div>
          <button id="btn-complete-guide" class="px-3 py-1.5 border border-terminal-green text-terminal-green text-xs hover:bg-terminal-green/10 transition-colors">
            ✓ Mark Complete
          </button>
        </div>
        <div id="completion-done" class="hidden flex items-center gap-2 py-2">
          <span class="text-terminal-green">✅</span>
          <span class="text-terminal-green text-xs font-bold">Guide complete!</span>
          <span class="text-terminal-muted text-[10px] ml-2">Progress saved</span>
        </div>
      </div>

      <!-- Related -->
      <div class="mt-6" id="guide-related">
        <slot name="related" />
      </div>
    </article>
  </div>
</BaseLayout>

<style is:global>
  .guide-content h2 {
    color: #00ff41;
    font-size: 1rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid #1a2332;
  }

  .guide-content h3 {
    color: #00d4ff;
    font-size: 0.9rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .guide-content h4 {
    color: #ffb000;
    font-size: 0.8rem;
    font-weight: 600;
    margin-top: 1.25rem;
    margin-bottom: 0.4rem;
  }

  .guide-content p {
    color: #d0d0d0;
    font-size: 0.8rem;
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }

  .guide-content ul, .guide-content ol {
    margin-bottom: 0.75rem;
    padding-left: 1.25rem;
  }

  .guide-content li {
    color: #d0d0d0;
    font-size: 0.8rem;
    line-height: 1.7;
    margin-bottom: 0.15rem;
  }

  .guide-content ul li::marker { color: #00ff41; }
  .guide-content ol li::marker { color: #ffb000; }

  .guide-content a {
    color: #00d4ff;
    text-decoration: underline;
    text-decoration-color: rgba(0, 212, 255, 0.3);
    text-underline-offset: 2px;
  }

  .guide-content a:hover {
    color: #00ff41;
    text-decoration-color: rgba(0, 255, 65, 0.4);
  }

  .guide-content code {
    background: rgba(26, 35, 50, 0.8);
    color: #00ff41;
    padding: 0.1rem 0.3rem;
    font-size: 0.75rem;
  }

  .guide-content pre {
    background: #0d0d0d;
    border: 1px solid #1a2332;
    padding: 0.75rem;
    margin-bottom: 0.75rem;
    overflow-x: auto;
  }

  .guide-content pre code {
    background: none;
    padding: 0;
    font-size: 0.75rem;
    color: #c0c0c0;
  }

  .guide-content blockquote {
    border-left: 2px solid #ffb000;
    padding: 0.5rem 0.75rem;
    margin: 1rem 0;
    background: rgba(255, 176, 0, 0.03);
  }

  .guide-content blockquote p {
    color: #a0a0a0;
    margin-bottom: 0;
  }

  /* Key Takeaway boxes */
  .guide-content blockquote.key-takeaway {
    border-left: none;
    border: 1px solid #00d4ff;
    padding: 0.75rem;
    background: rgba(0, 212, 255, 0.03);
    position: relative;
  }

  .guide-content blockquote.key-takeaway::before {
    content: '┤ KEY TAKEAWAY ├';
    position: absolute;
    top: -0.6em;
    left: 0.75rem;
    background: #0a0a0a;
    padding: 0 0.4rem;
    color: #00d4ff;
    font-size: 0.65rem;
    font-weight: 700;
  }

  .guide-content blockquote.key-takeaway p {
    color: #c0c0c0;
  }

  /* Check Yourself widgets */
  .guide-content blockquote.check-yourself {
    border-left: none;
    border: 1px solid #00ff41;
    padding: 0.75rem;
    background: rgba(0, 255, 65, 0.03);
    position: relative;
  }

  .guide-content blockquote.check-yourself::before {
    content: '┤ CHECK YOURSELF ├';
    position: absolute;
    top: -0.6em;
    left: 0.75rem;
    background: #0a0a0a;
    padding: 0 0.4rem;
    color: #00ff41;
    font-size: 0.65rem;
    font-weight: 700;
  }

  .check-answer {
    cursor: pointer;
    padding: 0.3rem 0.5rem;
    margin: 0.2rem 0;
    border: 1px solid #1a2332;
    font-size: 0.75rem;
    color: #a0a0a0;
    transition: all 0.2s ease;
  }

  .check-answer:hover {
    border-color: #00d4ff;
    color: #d0d0d0;
  }

  .check-answer.correct {
    border-color: #00ff41;
    color: #00ff41;
    background: rgba(0, 255, 65, 0.08);
  }

  .check-answer.incorrect {
    border-color: #ff4444;
    color: #ff4444;
    background: rgba(255, 68, 68, 0.08);
  }

  /* Collapsible H2 sections */
  .guide-content h2 {
    cursor: pointer;
    user-select: none;
  }

  .guide-content h2 .collapse-indicator {
    font-size: 0.7rem;
    color: #00ff41;
    margin-right: 0.3rem;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .guide-content h2:hover .collapse-indicator {
    opacity: 1;
  }

  .h2-section {
    overflow: hidden;
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }

  .h2-section.collapsed {
    max-height: 0 !important;
    opacity: 0;
  }

  .guide-content strong { color: #ffffff; font-weight: 600; }
  .guide-content em { color: #b0b0b0; }

  .guide-content hr {
    border: none;
    border-top: 1px solid #1a2332;
    margin: 1.5rem 0;
  }

  .guide-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0.75rem;
    font-size: 0.75rem;
  }

  .guide-content th {
    text-align: left;
    color: #00ff41;
    padding: 0.4rem;
    border-bottom: 1px solid #1a2332;
  }

  .guide-content td {
    padding: 0.4rem;
    border-bottom: 1px solid rgba(26, 35, 50, 0.5);
    color: #c0c0c0;
  }
</style>

<script>
  // Guide completion tracking
  (function() {
    const btn = document.getElementById('btn-complete-guide');
    const doneEl = document.getElementById('completion-done');
    const completionSection = document.querySelector('#guide-completion > div:first-child');
    if (!btn) return;

    // Extract guide ID from URL path: /guides/some-guide-id/ → some-guide-id
    const pathParts = window.location.pathname.replace(/^\/|\/$/, '').split('/');
    const guideId = pathParts.length >= 2 ? pathParts[pathParts.length - 1] : '';
    if (!guideId) return;

    // Check if already completed (from localStorage cache)
    function checkCompleted() {
      try {
        const cached = JSON.parse(localStorage.getItem('pt_progress') || '{}');
        const completed = cached.completed_guides || [];
        if (completed.includes(guideId)) {
          showCompleted();
        }
      } catch (e) {}
    }

    function showCompleted() {
      if (completionSection) completionSection.classList.add('hidden');
      if (doneEl) doneEl.classList.remove('hidden');
    }

    btn.addEventListener('click', async function() {
      btn.disabled = true;
      btn.textContent = 'Saving...';
      try {
        const { completeGuide } = await import('../scripts/privacy-score');
        await completeGuide(guideId);
        showCompleted();
      } catch (e) {
        // Fallback: save to localStorage directly
        try {
          const cached = JSON.parse(localStorage.getItem('pt_progress') || '{"completed_guides":[]}');
          if (!cached.completed_guides) cached.completed_guides = [];
          if (!cached.completed_guides.includes(guideId)) {
            cached.completed_guides.push(guideId);
          }
          localStorage.setItem('pt_progress', JSON.stringify(cached));
          showCompleted();
        } catch (e2) {
          btn.textContent = '✓ Mark Complete';
          btn.disabled = false;
        }
      }
    });

    checkCompleted();
  })();

  const tocLinks = document.querySelectorAll('[data-toc-link]');
  const headings = document.querySelectorAll('.guide-content h2, .guide-content h3');
  if (tocLinks.length > 0 && headings.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove('text-terminal-cyan'));
            const activeLink = document.querySelector(`[data-toc-link][href="#${entry.target.id}"]`);
            if (activeLink) activeLink.classList.add('text-terminal-cyan');
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px' }
    );
    headings.forEach((heading) => observer.observe(heading));
  }

  // ── Collapsible H2 Sections ──
  (function() {
    const guideContent = document.querySelector('.guide-content');
    if (!guideContent) return;

    const h2s = guideContent.querySelectorAll('h2');
    h2s.forEach(function(h2) {
      // Add toggle indicator
      var indicator = document.createElement('span');
      indicator.className = 'collapse-indicator';
      indicator.textContent = '[-]';
      h2.insertBefore(indicator, h2.firstChild);

      // Wrap content between this h2 and next h2 in a div
      var section = document.createElement('div');
      section.className = 'h2-section';
      var sibling = h2.nextElementSibling;
      while (sibling && sibling.tagName !== 'H2') {
        var next = sibling.nextElementSibling;
        section.appendChild(sibling);
        sibling = next;
      }
      h2.after(section);
      // Start collapsed
      section.classList.add('collapsed');
      section.style.maxHeight = '0px';
      indicator.textContent = '[+]';

      h2.addEventListener('click', function() {
        var isCollapsed = section.classList.contains('collapsed');
        if (isCollapsed) {
          section.classList.remove('collapsed');
          section.style.maxHeight = section.scrollHeight + 'px';
          indicator.textContent = '[-]';
        } else {
          section.style.maxHeight = section.scrollHeight + 'px';
          requestAnimationFrame(function() {
            section.classList.add('collapsed');
          });
          indicator.textContent = '[+]';
        }
      });
    });
  })();

  // ── Key Takeaway Box Detection ──
  (function() {
    var bqs = document.querySelectorAll('.guide-content blockquote');
    bqs.forEach(function(bq) {
      var firstP = bq.querySelector('p');
      if (!firstP) return;
      var text = firstP.innerHTML;
      if (text.startsWith('<strong>KEY TAKEAWAY:</strong>') || text.startsWith('<strong>KEY TAKEAWAY</strong>:')) {
        bq.classList.add('key-takeaway');
        firstP.innerHTML = text.replace(/<strong>KEY TAKEAWAY:?<\/strong>:?\s*/, '');
      }
      if (text.startsWith('<strong>CHECK YOURSELF:</strong>') || text.startsWith('<strong>CHECK YOURSELF</strong>:')) {
        bq.classList.add('check-yourself');
        // Parse check yourself quiz answers
        var items = bq.querySelectorAll('li');
        firstP.innerHTML = text.replace(/<strong>CHECK YOURSELF:?<\/strong>:?\s*/, '');
        items.forEach(function(li) {
          var raw = li.textContent.trim();
          var isCorrect = raw.startsWith('[x]') || raw.startsWith('[X]');
          li.textContent = raw.replace(/^\[[ xX]\]\s*/, '');
          li.className = 'check-answer';
          li.dataset.correct = isCorrect ? 'true' : 'false';
          li.style.listStyle = 'none';
          li.addEventListener('click', function() {
            if (li.classList.contains('correct') || li.classList.contains('incorrect')) return;
            if (isCorrect) {
              li.classList.add('correct');
              li.textContent = '✓ ' + li.textContent;
            } else {
              li.classList.add('incorrect');
              li.textContent = '✗ ' + li.textContent;
              setTimeout(function() { li.classList.remove('incorrect'); li.textContent = li.textContent.replace('✗ ', ''); }, 1500);
            }
          });
        });
      }
    });
  })();
</script>
