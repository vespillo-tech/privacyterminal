---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;

const aboutEntry = await getEntry('site', 'about-page');
const ab = aboutEntry?.data as {
  what_is_this: string[];
  principles: Array<{ title: string; description: string }>;
  transparency: Array<{ key: string; value: string; color: string; link?: string }>;
  verification_steps: string[];
  tech_stack: string;
};

// Map color names to Tailwind classes
const tColor: Record<string, string> = {
  red:  'text-terminal-red',
  cyan: 'text-terminal-cyan',
  gray: 'text-gray-400',
  green: 'text-terminal-green',
  amber: 'text-terminal-amber',
};
---
<BaseLayout title="About Privacy Terminal — Open Source Privacy Tools & Transparency" description="Privacy Terminal is an open-source collection of browser-based privacy tools and guides. Zero tracking, zero cookies, zero external requests. Verify our claims yourself." statusLeft="about" statusRight="transparency report">
  <div class="mb-4">
    <div class="text-terminal-green text-glow-green font-bold mb-1">~/about</div>
  </div>

  <div class="max-w-3xl space-y-0">
    <!-- What is this -->
    <div class="tui-box p-4">
      <span class="tui-box-title text-terminal-green">├ WHAT IS THIS ┤</span>
      <div class="mt-1 text-sm text-gray-300 leading-relaxed space-y-2">
        {ab.what_is_this.map((para: string) => (
          <p>{para}</p>
        ))}
      </div>
    </div>

    <!-- Principles -->
    <div class="tui-box p-4">
      <span class="tui-box-title text-terminal-cyan">├ PRINCIPLES ┤</span>
      <div class="mt-1 space-y-3 text-xs">
        {ab.principles.map((p: { title: string; description: string }) => (
          <div>
            <span class="text-terminal-cyan font-bold">{p.title}</span>
            <span class="text-terminal-muted"> — {p.description}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Transparency -->
    <div class="tui-box p-4">
      <span class="tui-box-title text-terminal-amber">├ TRANSPARENCY ┤</span>
      <div class="mt-1 text-xs space-y-1 font-mono">
        {ab.transparency.map((item: { key: string; value: string; color: string; link?: string }) => (
          <div>
            <span class="text-terminal-green">{item.key}:</span>{' '}
            {item.link ? (
              <a href={item.link} class="text-terminal-cyan">{item.value}</a>
            ) : (
              <span class:list={[tColor[item.color] ?? 'text-gray-400']}>{item.value}</span>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Verify -->
    <div class="tui-box p-4">
      <span class="tui-box-title text-terminal-green">├ HOW TO VERIFY ┤</span>
      <div class="mt-1 text-xs text-gray-300 space-y-2">
        {ab.verification_steps.map((step: string, i: number) => (
          <div><span class="text-terminal-green">{i + 1}.</span> {step}</div>
        ))}
      </div>
    </div>

    <!-- Tech -->
    <div class="text-xs text-terminal-muted py-3">
      <span class="text-terminal-green">stack:</span> {ab.tech_stack}
    </div>
  </div>
</BaseLayout>
