---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
export const prerender = true;

const allGuides = await getCollection('guides');

function diffBar(d: number): string {
  return '█'.repeat(d || 1) + '░'.repeat(5 - (d || 1));
}
const publishedGuides = allGuides.filter((g) => !g.data.draft);

const categories = [
  { id: 'foundations', label: 'FOUNDATIONS', color: 'terminal-green', desc: 'Start here. Understand tracking, threats, and how to think about privacy.' },
  { id: 'essentials', label: 'ESSENTIALS', color: 'terminal-cyan', desc: 'Practical steps: browsers, passwords, email, communication.' },
  { id: 'intermediate', label: 'INTERMEDIATE', color: 'terminal-amber', desc: 'VPNs, DNS, metadata, and what your devices reveal.' },
  { id: 'advanced', label: 'ADVANCED', color: 'terminal-red', desc: 'Maximum privacy. Operational security and advanced techniques.' },
];
---

<BaseLayout title="Privacy Guides — Learn to Protect Your Digital Privacy | Privacy Terminal" description="Privacy education from basics to advanced. Learn how tracking works, who wants your data, and practical steps to protect yourself. No prescriptions, just facts." statusLeft="guides index" statusRight={`${publishedGuides.length} published`}>
  <div class="mb-4">
    <h1 class="text-terminal-green text-glow-green font-bold mb-1 text-base">~/guides</h1>
    <div class="text-terminal-muted text-xs">Privacy education organized by depth. Every guide shows the full spectrum — we inform, not prescribe.</div>
    <div class="mt-2">
      <a href="/skill-tree" class="text-terminal-green text-xs hover:text-terminal-cyan no-underline font-bold">▸ Use the Skill Tree for guided progression with progress tracking →</a>
    </div>
  </div>

  <div class="space-y-0">
    {categories.map((cat) => {
      const catGuides = publishedGuides
        .filter((g) => g.data.category === cat.id)
        .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

      return (
        <div class="tui-box p-3">
          <span class={`tui-box-title text-${cat.color}`}>┤ {cat.label} ├</span>
          <div class="mt-1">
            <div class="text-terminal-muted text-xs mb-2">{cat.desc}</div>
            {catGuides.length > 0 ? (
              <div class="space-y-1">
                {catGuides.map((guide, i) => (
                  <a
                    href={`/guides/${guide.id}`}
                    class="flex items-center gap-2 py-0.5 px-2 hover:bg-terminal-green/5 transition-colors group"
                  >
                    <span class={`text-${cat.color}`}>{i === catGuides.length - 1 ? '└─' : '├─'}</span>
                    <span class="text-gray-300 group-hover:text-terminal-green text-xs" data-guide-title>{guide.data.title}</span>
                    <span class="text-terminal-muted text-[10px] ml-auto flex items-center gap-2">
                      <span class="guide-completion-badge hidden text-terminal-green" data-guide-id={guide.id}>[✓]</span>
                      {guide.data.difficulty && <span title={`Difficulty ${guide.data.difficulty}/5`}>{diffBar(guide.data.difficulty)}</span>}
                      {guide.data.readingTime && <span>{guide.data.readingTime}</span>}
                    </span>
                  </a>
                ))}
              </div>
            ) : (
              <div class="text-terminal-muted text-xs px-2 opacity-60">└─ coming soon</div>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <!-- Guide completion progress -->
  <div class="tui-box p-2 mb-0" id="guide-progress-bar">
    <div class="flex items-center justify-between text-xs">
      <span class="text-terminal-muted">progress:</span>
      <span id="guide-progress-text" class="text-terminal-green">loading...</span>
    </div>
  </div>

  <hr class="tui-hr" />
  <div class="grid grid-cols-2 gap-4 text-xs text-terminal-muted py-2">
    <div><span class="text-terminal-green font-bold">Landscape Principle:</span> Every guide presents the full spectrum with honest trade-offs.</div>
    <div><span class="text-terminal-green font-bold">Source Attribution:</span> Claims backed by evidence. We cite sources and explain methodology.</div>
  </div>
  <script>
    (function() {
      try {
        var cached = JSON.parse(localStorage.getItem('pt_progress') || '{}');
        var completed = cached.guides_completed || [];
        var badges = document.querySelectorAll('.guide-completion-badge');
        var total = badges.length;
        var done = 0;
        badges.forEach(function(badge) {
          var id = badge.dataset.guideId;
          if (completed.includes(id)) {
            badge.classList.remove('hidden');
            done++;
          }
        });
        var el = document.getElementById('guide-progress-text');
        if (el) {
          var bar = '█'.repeat(Math.round((done/Math.max(total,1))*12)) + '░'.repeat(12 - Math.round((done/Math.max(total,1))*12));
          el.textContent = done + '/' + total + ' completed ' + bar;
        }
      } catch(e) {}
    })();
  </script>
</BaseLayout>
