---
import ToolLayout from '../../layouts/ToolLayout.astro';
export const prerender = true;
---

<ToolLayout
  title="Hash Generator & Verifier"
  toolName="hash-generator"
  toolVersion="1.0.0"
  description="Generate and verify cryptographic hashes. SHA-1, SHA-256, SHA-384, SHA-512, and MD5 — all computed client-side using the Web Crypto API. Your data never leaves your browser."
>
  <!-- Tool controls -->
  <Fragment slot="controls">
    <div class="space-y-4">
      <!-- Mode selector -->
      <div class="flex gap-2 text-xs">
        <button id="mode-text" class="px-3 py-1.5 rounded border border-terminal-green bg-terminal-green/10 text-terminal-green transition-colors" data-mode="text">
          > text input
        </button>
        <button id="mode-file" class="px-3 py-1.5 rounded border border-terminal-border text-terminal-muted hover:border-terminal-cyan hover:text-terminal-cyan transition-colors" data-mode="file">
          > file input
        </button>
        <button id="mode-verify" class="px-3 py-1.5 rounded border border-terminal-border text-terminal-muted hover:border-terminal-amber hover:text-terminal-amber transition-colors" data-mode="verify">
          > verify hash
        </button>
      </div>

      <!-- Algorithm selector -->
      <div class="flex flex-wrap gap-2 text-xs">
        <span class="text-terminal-muted py-1">algorithm:</span>
        <button class="algo-btn px-2 py-1 rounded border border-terminal-green bg-terminal-green/10 text-terminal-green" data-algo="SHA-256">SHA-256</button>
        <button class="algo-btn px-2 py-1 rounded border border-terminal-border text-terminal-muted hover:text-terminal-cyan" data-algo="SHA-512">SHA-512</button>
        <button class="algo-btn px-2 py-1 rounded border border-terminal-border text-terminal-muted hover:text-terminal-cyan" data-algo="SHA-384">SHA-384</button>
        <button class="algo-btn px-2 py-1 rounded border border-terminal-border text-terminal-muted hover:text-terminal-cyan" data-algo="SHA-1">SHA-1</button>
        <button class="algo-btn px-2 py-1 rounded border border-terminal-border text-terminal-muted hover:text-terminal-cyan" data-algo="MD5">MD5</button>
      </div>

      <!-- Text input panel -->
      <div id="panel-text" class="">
        <textarea
          id="text-input"
          class="w-full bg-terminal-bg border border-terminal-border rounded p-3 text-sm text-gray-300 font-mono placeholder-terminal-muted focus:outline-none focus:border-terminal-green/50 resize-y min-h-[100px]"
          placeholder="Enter text to hash..."
          rows="4"
        ></textarea>
        <div class="flex items-center gap-3 mt-2">
          <button id="btn-hash-text" class="px-4 py-2 rounded border border-terminal-green text-terminal-green text-xs font-bold hover:bg-terminal-green/10 transition-colors">
            $ generate hash
          </button>
          <button id="btn-clear" class="px-3 py-1.5 rounded border border-terminal-border text-terminal-muted text-xs hover:text-terminal-red hover:border-terminal-red transition-colors">
            clear
          </button>
          <span id="text-size" class="text-terminal-muted text-xs ml-auto">0 bytes</span>
        </div>
      </div>

      <!-- File input panel -->
      <div id="panel-file" class="hidden">
        <div
          id="drop-zone"
          class="border-2 border-dashed border-terminal-border rounded-lg p-8 text-center cursor-pointer hover:border-terminal-cyan/50 transition-colors"
        >
          <div class="text-terminal-cyan text-2xl mb-2">◈</div>
          <p class="text-terminal-muted text-sm">Drop a file here or click to select</p>
          <p class="text-terminal-muted text-xs mt-1">Any file type — processed entirely in your browser</p>
          <input type="file" id="file-input" class="hidden" />
        </div>
        <div id="file-info" class="hidden mt-2 text-xs text-terminal-muted">
          <span id="file-name"></span> — <span id="file-size-display"></span>
        </div>
      </div>

      <!-- Verify panel -->
      <div id="panel-verify" class="hidden space-y-3">
        <textarea
          id="verify-input"
          class="w-full bg-terminal-bg border border-terminal-border rounded p-3 text-sm text-gray-300 font-mono placeholder-terminal-muted focus:outline-none focus:border-terminal-green/50 resize-y min-h-[80px]"
          placeholder="Enter text to hash and verify..."
          rows="3"
        ></textarea>
        <div>
          <label class="text-terminal-muted text-xs block mb-1">expected hash (hex):</label>
          <input
            id="verify-expected"
            type="text"
            class="w-full bg-terminal-bg border border-terminal-border rounded p-2 text-sm text-gray-300 font-mono placeholder-terminal-muted focus:outline-none focus:border-terminal-amber/50"
            placeholder="Paste expected hash value..."
          />
        </div>
        <button id="btn-verify" class="px-4 py-2 rounded border border-terminal-amber text-terminal-amber text-xs font-bold hover:bg-terminal-amber/10 transition-colors">
          $ verify hash
        </button>
      </div>
    </div>
  </Fragment>

  <!-- Results area -->
  <Fragment slot="results">
    <div id="results-container" class="hidden">
      <h3 class="text-terminal-amber text-glow-amber text-xs uppercase tracking-widest mb-3">
        > Results
      </h3>
      <div id="results-list" class="space-y-3"></div>
    </div>
  </Fragment>

  <!-- Related content -->
  <div class="border-t border-terminal-border pt-6 mt-8">
    <h3 class="text-terminal-amber text-glow-amber text-xs uppercase tracking-widest mb-3">
      > About Cryptographic Hashes
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs text-terminal-muted">
      <div>
        <p class="mb-2"><strong class="text-white">What is a hash?</strong> A cryptographic hash function takes any input and produces a fixed-size string of characters. The same input always produces the same hash, but even a tiny change in input produces a completely different hash.</p>
        <p><strong class="text-white">SHA-256</strong> is the gold standard — used in Bitcoin, TLS certificates, and file integrity verification. <strong class="text-white">SHA-512</strong> provides a longer hash for additional security.</p>
      </div>
      <div>
        <p class="mb-2"><strong class="text-white">When to use each:</strong></p>
        <ul class="space-y-1 ml-3">
          <li><span class="text-terminal-green">SHA-256</span> — General purpose, file verification, checksums</li>
          <li><span class="text-terminal-green">SHA-512</span> — When you need maximum hash length</li>
          <li><span class="text-terminal-green">SHA-384</span> — Truncated SHA-512, used in some TLS suites</li>
          <li><span class="text-terminal-amber">SHA-1</span> — Legacy only, known vulnerabilities</li>
          <li><span class="text-terminal-red">MD5</span> — Broken for security, still used for non-security checksums</li>
        </ul>
      </div>
    </div>
  </div>
</ToolLayout>

<script>
  // === MD5 Implementation (pure JS, not in Web Crypto API) ===
  function md5(input: Uint8Array): string {
    function safeAdd(x: number, y: number): number {
      const lsw = (x & 0xffff) + (y & 0xffff);
      const msw = (x >> 16) + (y >> 16) + (lsw >> 16);
      return (msw << 16) | (lsw & 0xffff);
    }
    function bitRotateLeft(num: number, cnt: number): number {
      return (num << cnt) | (num >>> (32 - cnt));
    }
    function md5cmn(q: number, a: number, b: number, x: number, s: number, t: number): number {
      return safeAdd(bitRotateLeft(safeAdd(safeAdd(a, q), safeAdd(x, t)), s), b);
    }
    function md5ff(a: number, b: number, c: number, d: number, x: number, s: number, t: number): number {
      return md5cmn((b & c) | (~b & d), a, b, x, s, t);
    }
    function md5gg(a: number, b: number, c: number, d: number, x: number, s: number, t: number): number {
      return md5cmn((b & d) | (c & ~d), a, b, x, s, t);
    }
    function md5hh(a: number, b: number, c: number, d: number, x: number, s: number, t: number): number {
      return md5cmn(b ^ c ^ d, a, b, x, s, t);
    }
    function md5ii(a: number, b: number, c: number, d: number, x: number, s: number, t: number): number {
      return md5cmn(c ^ (b | ~d), a, b, x, s, t);
    }

    // Pre-processing: add padding
    const len = input.length;
    const bitLen = len * 8;
    const padLen = ((len + 8) >>> 6 << 4) + 16;
    const padded = new Uint8Array(padLen * 4);
    padded.set(input);
    padded[len] = 0x80;
    // Length in bits as 64-bit little-endian
    const view = new DataView(padded.buffer);
    view.setUint32((padLen - 2) * 4, bitLen >>> 0, true);
    view.setUint32((padLen - 1) * 4, 0, true);

    // Process blocks
    const words = new Uint32Array(padded.buffer);
    let a = 1732584193, b = -271733879, c = -1732584194, d = 271733878;

    for (let i = 0; i < words.length; i += 16) {
      const olda = a, oldb = b, oldc = c, oldd = d;
      a = md5ff(a,b,c,d,words[i],7,-680876936);d = md5ff(d,a,b,c,words[i+1],12,-389564586);
      c = md5ff(c,d,a,b,words[i+2],17,606105819);b = md5ff(b,c,d,a,words[i+3],22,-1044525330);
      a = md5ff(a,b,c,d,words[i+4],7,-176418897);d = md5ff(d,a,b,c,words[i+5],12,1200080426);
      c = md5ff(c,d,a,b,words[i+6],17,-1473231341);b = md5ff(b,c,d,a,words[i+7],22,-45705983);
      a = md5ff(a,b,c,d,words[i+8],7,1770035416);d = md5ff(d,a,b,c,words[i+9],12,-1958414417);
      c = md5ff(c,d,a,b,words[i+10],17,-42063);b = md5ff(b,c,d,a,words[i+11],22,-1990404162);
      a = md5ff(a,b,c,d,words[i+12],7,1804603682);d = md5ff(d,a,b,c,words[i+13],12,-40341101);
      c = md5ff(c,d,a,b,words[i+14],17,-1502002290);b = md5ff(b,c,d,a,words[i+15],22,1236535329);
      a = md5gg(a,b,c,d,words[i+1],5,-165796510);d = md5gg(d,a,b,c,words[i+6],9,-1069501632);
      c = md5gg(c,d,a,b,words[i+11],14,643717713);b = md5gg(b,c,d,a,words[i],20,-373897302);
      a = md5gg(a,b,c,d,words[i+5],5,-701558691);d = md5gg(d,a,b,c,words[i+10],9,38016083);
      c = md5gg(c,d,a,b,words[i+15],14,-660478335);b = md5gg(b,c,d,a,words[i+4],20,-405537848);
      a = md5gg(a,b,c,d,words[i+9],5,568446438);d = md5gg(d,a,b,c,words[i+14],9,-1019803690);
      c = md5gg(c,d,a,b,words[i+3],14,-187363961);b = md5gg(b,c,d,a,words[i+8],20,1163531501);
      a = md5gg(a,b,c,d,words[i+13],5,-1444681467);d = md5gg(d,a,b,c,words[i+2],9,-51403784);
      c = md5gg(c,d,a,b,words[i+7],14,1735328473);b = md5gg(b,c,d,a,words[i+12],20,-1926607734);
      a = md5hh(a,b,c,d,words[i+5],4,-378558);d = md5hh(d,a,b,c,words[i+8],11,-2022574463);
      c = md5hh(c,d,a,b,words[i+11],16,1839030562);b = md5hh(b,c,d,a,words[i+14],23,-35309556);
      a = md5hh(a,b,c,d,words[i+1],4,-1530992060);d = md5hh(d,a,b,c,words[i+4],11,1272893353);
      c = md5hh(c,d,a,b,words[i+7],16,-155497632);b = md5hh(b,c,d,a,words[i+10],23,-1094730640);
      a = md5hh(a,b,c,d,words[i+13],4,681279174);d = md5hh(d,a,b,c,words[i],11,-358537222);
      c = md5hh(c,d,a,b,words[i+3],16,-722521979);b = md5hh(b,c,d,a,words[i+6],23,76029189);
      a = md5hh(a,b,c,d,words[i+9],4,-640364487);d = md5hh(d,a,b,c,words[i+12],11,-421815835);
      c = md5hh(c,d,a,b,words[i+15],16,530742520);b = md5hh(b,c,d,a,words[i+2],23,-995338651);
      a = md5ii(a,b,c,d,words[i],6,-198630844);d = md5ii(d,a,b,c,words[i+7],10,1126891415);
      c = md5ii(c,d,a,b,words[i+14],15,-1416354905);b = md5ii(b,c,d,a,words[i+5],21,-57434055);
      a = md5ii(a,b,c,d,words[i+12],6,1700485571);d = md5ii(d,a,b,c,words[i+3],10,-1894986606);
      c = md5ii(c,d,a,b,words[i+10],15,-1051523);b = md5ii(b,c,d,a,words[i+1],21,-2054922799);
      a = md5ii(a,b,c,d,words[i+8],6,1873313359);d = md5ii(d,a,b,c,words[i+15],10,-30611744);
      c = md5ii(c,d,a,b,words[i+6],15,-1560198380);b = md5ii(b,c,d,a,words[i+13],21,1309151649);
      a = md5ii(a,b,c,d,words[i+4],6,-145523070);d = md5ii(d,a,b,c,words[i+11],10,-1120210379);
      c = md5ii(c,d,a,b,words[i+2],15,718787259);b = md5ii(b,c,d,a,words[i+9],21,-343485551);
      a = safeAdd(a,olda);b = safeAdd(b,oldb);c = safeAdd(c,oldc);d = safeAdd(d,oldd);
    }

    const hex = '0123456789abcdef';
    let result = '';
    for (const val of [a, b, c, d]) {
      for (let j = 0; j < 4; j++) {
        result += hex[(val >> (j * 8 + 4)) & 0xf] + hex[(val >> (j * 8)) & 0xf];
      }
    }
    return result;
  }

  // === Helpers ===
  const PT = (window as any).privacyTerminal;

  function formatBytes(bytes: number): string {
    if (bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  function bufToHex(buf: ArrayBuffer): string {
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
  }

  function hexToBase64(hex: string): string {
    const bytes = hex.match(/.{2}/g)?.map(b => parseInt(b, 16)) || [];
    return btoa(String.fromCharCode(...bytes));
  }

  async function computeHash(algo: string, data: Uint8Array): Promise<string> {
    if (algo === 'MD5') {
      return md5(data);
    }
    const buf = await crypto.subtle.digest(algo, data);
    return bufToHex(buf);
  }

  function createResultCard(algo: string, hex: string, timeMs: number): HTMLElement {
    const b64 = hexToBase64(hex);
    const card = document.createElement('div');
    card.className = 'border border-terminal-border rounded p-4 bg-terminal-bg/50';
    card.innerHTML = `
      <div class="flex items-center justify-between mb-2">
        <span class="text-terminal-green text-xs font-bold">${algo}</span>
        <span class="text-terminal-muted text-[10px]">${timeMs.toFixed(1)}ms</span>
      </div>
      <div class="space-y-2">
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-terminal-muted text-[10px] uppercase">hex</span>
            <button class="copy-btn text-terminal-cyan text-[10px] hover:text-terminal-green transition-colors" data-value="${hex}">copy</button>
          </div>
          <div class="bg-black/40 rounded p-2 text-xs text-gray-300 font-mono break-all select-all">${hex}</div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-terminal-muted text-[10px] uppercase">base64</span>
            <button class="copy-btn text-terminal-cyan text-[10px] hover:text-terminal-green transition-colors" data-value="${b64}">copy</button>
          </div>
          <div class="bg-black/40 rounded p-2 text-xs text-gray-300 font-mono break-all select-all">${b64}</div>
        </div>
      </div>
    `;
    // Copy button handlers
    card.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const val = (btn as HTMLElement).dataset.value || '';
        await navigator.clipboard.writeText(val);
        const orig = btn.textContent;
        btn.textContent = 'copied!';
        btn.classList.remove('text-terminal-cyan');
        btn.classList.add('text-terminal-green');
        setTimeout(() => {
          btn.textContent = orig;
          btn.classList.remove('text-terminal-green');
          btn.classList.add('text-terminal-cyan');
        }, 1500);
      });
    });
    return card;
  }

  // === State ===
  let currentMode = 'text';
  let currentAlgo = 'SHA-256';
  let fileData: Uint8Array | null = null;

  // === Mode switching ===
  const modeButtons = document.querySelectorAll('[data-mode]');
  const panels = {
    text: document.getElementById('panel-text')!,
    file: document.getElementById('panel-file')!,
    verify: document.getElementById('panel-verify')!,
  };

  modeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      currentMode = (btn as HTMLElement).dataset.mode!;
      modeButtons.forEach(b => {
        b.classList.remove('border-terminal-green', 'bg-terminal-green/10', 'text-terminal-green',
          'border-terminal-cyan', 'bg-terminal-cyan/10', 'text-terminal-cyan',
          'border-terminal-amber', 'bg-terminal-amber/10', 'text-terminal-amber');
        b.classList.add('border-terminal-border', 'text-terminal-muted');
      });
      const colors: Record<string, string[]> = {
        text: ['border-terminal-green', 'bg-terminal-green/10', 'text-terminal-green'],
        file: ['border-terminal-cyan', 'bg-terminal-cyan/10', 'text-terminal-cyan'],
        verify: ['border-terminal-amber', 'bg-terminal-amber/10', 'text-terminal-amber'],
      };
      btn.classList.remove('border-terminal-border', 'text-terminal-muted');
      btn.classList.add(...colors[currentMode]);
      Object.values(panels).forEach(p => p.classList.add('hidden'));
      panels[currentMode as keyof typeof panels].classList.remove('hidden');
      PT?.appendLog(`Switched to ${currentMode} mode`, 'info');
    });
  });

  // === Algorithm switching ===
  const algoButtons = document.querySelectorAll('.algo-btn');
  algoButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      currentAlgo = (btn as HTMLElement).dataset.algo!;
      algoButtons.forEach(b => {
        b.classList.remove('border-terminal-green', 'bg-terminal-green/10', 'text-terminal-green');
        b.classList.add('border-terminal-border', 'text-terminal-muted');
      });
      btn.classList.remove('border-terminal-border', 'text-terminal-muted');
      btn.classList.add('border-terminal-green', 'bg-terminal-green/10', 'text-terminal-green');
      PT?.appendLog(`Algorithm set to ${currentAlgo}`, 'info');
    });
  });

  // === Text input ===
  const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
  const textSize = document.getElementById('text-size')!;
  textInput.addEventListener('input', () => {
    const bytes = new TextEncoder().encode(textInput.value).length;
    textSize.textContent = formatBytes(bytes);
  });

  // === File handling ===
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const fileInfo = document.getElementById('file-info')!;
  const fileName = document.getElementById('file-name')!;
  const fileSizeDisplay = document.getElementById('file-size-display')!;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-terminal-cyan', 'bg-terminal-cyan/5');
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-terminal-cyan', 'bg-terminal-cyan/5');
  });
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-terminal-cyan', 'bg-terminal-cyan/5');
    const file = e.dataTransfer?.files[0];
    if (file) loadFile(file);
  });
  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) loadFile(file);
  });

  function loadFile(file: File) {
    PT?.appendLog(`Loading file: ${file.name} (${formatBytes(file.size)})`, 'info');
    fileName.textContent = file.name;
    fileSizeDisplay.textContent = formatBytes(file.size);
    fileInfo.classList.remove('hidden');
    const reader = new FileReader();
    reader.onload = () => {
      fileData = new Uint8Array(reader.result as ArrayBuffer);
      PT?.appendLog(`File loaded: ${formatBytes(fileData.length)} ready to hash`, 'success');
    };
    reader.readAsArrayBuffer(file);
  }

  // === Hash text ===
  document.getElementById('btn-hash-text')!.addEventListener('click', async () => {
    const text = textInput.value;
    if (!text) { PT?.appendLog('No input text provided', 'warn'); return; }
    await hashAndDisplay(new TextEncoder().encode(text), `text (${formatBytes(new TextEncoder().encode(text).length)})`);
  });

  // === Hash file (auto-trigger when in file mode) ===
  // Add a hash button for file mode
  const filePanel = document.getElementById('panel-file')!;
  const fileHashBtn = document.createElement('button');
  fileHashBtn.id = 'btn-hash-file';
  fileHashBtn.className = 'mt-3 px-4 py-2 rounded border border-terminal-cyan text-terminal-cyan text-xs font-bold hover:bg-terminal-cyan/10 transition-colors hidden';
  fileHashBtn.textContent = '$ generate hash';
  filePanel.appendChild(fileHashBtn);

  // Show file hash button when file is loaded
  const origLoadFile = loadFile;
  const fileHashBtnEl = document.getElementById('btn-hash-file')!;
  new MutationObserver(() => {
    if (!fileInfo.classList.contains('hidden')) fileHashBtnEl.classList.remove('hidden');
  }).observe(fileInfo, { attributes: true, attributeFilter: ['class'] });

  fileHashBtnEl.addEventListener('click', async () => {
    if (!fileData) { PT?.appendLog('No file loaded', 'warn'); return; }
    await hashAndDisplay(fileData, `file (${formatBytes(fileData.length)})`);
  });

  // === Verify ===
  document.getElementById('btn-verify')!.addEventListener('click', async () => {
    const text = (document.getElementById('verify-input') as HTMLTextAreaElement).value;
    const expected = (document.getElementById('verify-expected') as HTMLInputElement).value.trim().toLowerCase();
    if (!text) { PT?.appendLog('No input text provided', 'warn'); return; }
    if (!expected) { PT?.appendLog('No expected hash provided', 'warn'); return; }

    PT?.setToolStatus('running');
    PT?.appendLog(`Verifying ${currentAlgo} hash...`, 'info');

    const data = new TextEncoder().encode(text);
    const start = performance.now();
    const hex = await computeHash(currentAlgo, data);
    const elapsed = performance.now() - start;

    const match = hex === expected;
    const resultsContainer = document.getElementById('results-container')!;
    const resultsList = document.getElementById('results-list')!;
    resultsContainer.classList.remove('hidden');

    const card = document.createElement('div');
    card.className = `border rounded p-4 ${match ? 'border-terminal-green bg-terminal-green/5' : 'border-terminal-red bg-terminal-red/5'}`;
    card.innerHTML = `
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xl">${match ? '✓' : '✗'}</span>
        <span class="${match ? 'text-terminal-green text-glow-green' : 'text-terminal-red'} text-sm font-bold">
          ${match ? 'HASH MATCH' : 'HASH MISMATCH'}
        </span>
        <span class="text-terminal-muted text-[10px] ml-auto">${currentAlgo} · ${elapsed.toFixed(1)}ms</span>
      </div>
      <div class="space-y-2 text-xs">
        <div>
          <span class="text-terminal-muted">computed:</span>
          <div class="bg-black/40 rounded p-2 font-mono break-all mt-1 ${match ? 'text-terminal-green' : 'text-gray-300'}">${hex}</div>
        </div>
        <div>
          <span class="text-terminal-muted">expected:</span>
          <div class="bg-black/40 rounded p-2 font-mono break-all mt-1 ${match ? 'text-terminal-green' : 'text-terminal-red'}">${expected}</div>
        </div>
      </div>
    `;
    resultsList.prepend(card);

    PT?.appendLog(
      match ? `${currentAlgo} hash MATCHES expected value` : `${currentAlgo} hash DOES NOT MATCH expected value`,
      match ? 'success' : 'error'
    );
    PT?.setToolStatus(match ? 'complete' : 'error');
  });

  // === Core hash + display ===
  async function hashAndDisplay(data: Uint8Array, label: string) {
    PT?.setToolStatus('running');
    PT?.appendLog(`Hashing ${label} with ${currentAlgo}...`, 'info');

    const resultsContainer = document.getElementById('results-container')!;
    const resultsList = document.getElementById('results-list')!;
    resultsContainer.classList.remove('hidden');

    const start = performance.now();
    try {
      const hex = await computeHash(currentAlgo, data);
      const elapsed = performance.now() - start;

      const card = createResultCard(currentAlgo, hex, elapsed);
      resultsList.prepend(card);

      PT?.appendLog(`${currentAlgo}: ${hex.substring(0, 32)}...`, 'success');
      PT?.setToolStatus('complete');
    } catch (err) {
      PT?.appendLog(`Error: ${err}`, 'error');
      PT?.setToolStatus('error');
    }
  }

  // === Clear ===
  document.getElementById('btn-clear')!.addEventListener('click', () => {
    textInput.value = '';
    textSize.textContent = '0 bytes';
    const resultsList = document.getElementById('results-list')!;
    resultsList.innerHTML = '';
    document.getElementById('results-container')!.classList.add('hidden');
    PT?.appendLog('Cleared input and results', 'info');
    PT?.setToolStatus('ready');
  });
</script>
