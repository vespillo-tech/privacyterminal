{id:'financial_fraud',label:'Financial Fraud',desc:'Identity theft, account takeover, SIM swap',color:'amber'},
{id:'location_tracking',label:'Location Tracking',desc:'Physical movement monitoring',color:'amber'},
{id:'doxxing_harassment',label:'Doxxing and Harassment',desc:'Personal info exposure, coordinated attacks',color:'red'},
{id:'stalking_domestic',label:'Stalking and Domestic',desc:'Interpersonal surveillance, device monitoring',color:'red'},
{id:'social_engineering',label:'Social Engineering',desc:'Phishing, pretexting, manipulation attacks',color:'amber'},
{id:'device_compromise',label:'Device Compromise',desc:'Malware, physical access, device theft',color:'amber'},
{id:'network_attacks',label:'Network Attacks',desc:'MITM, rogue WiFi, DNS hijacking',color:'amber'},
{id:'algorithmic_disc',label:'Algorithmic Discrimination',desc:'Insurance, credit, employment profiling',color:'amber'},
{id:'data_broker',label:'Data Broker Profiling',desc:'People-search sites, background check companies',color:'amber'},
{id:'border_travel',label:'Border and Travel',desc:'Device searches, forced decryption at borders',color:'amber'},
{id:'employer_monitoring',label:'Employer Monitoring',desc:'Workplace surveillance, BYOD, productivity scoring',color:'amber'},
{id:'legal_subpoena',label:'Legal and Subpoena',desc:'Data requests, compelled disclosure',color:'amber'},
{id:'ai_deepfakes',label:'AI Deepfakes',desc:'AI impersonation, voice cloning, synthetic media',color:'amber'},
{id:'genetic_dna',label:'Genetic and DNA Data',desc:'Permanent biometric exposure, bankruptcy data sale',color:'red'},
{id:'health_reproductive',label:'Health and Reproductive',desc:'Health app data weaponization, wearable sharing',color:'red'},
{id:'connected_vehicle',label:'Connected Vehicle',desc:'Car tracking, driving behavior, cabin audio',color:'amber'},
{id:'smart_home_iot',label:'Smart Home and IoT',desc:'Voice assistants, smart TVs, ambient surveillance',color:'amber'},
{id:'data_misuse_creep',label:'Data Purpose Creep',desc:'Data used beyond original consent',color:'amber'},
{id:'ai_training_harvest',label:'AI Training Harvest',desc:'Content scraped for AI training without consent',color:'amber'},
