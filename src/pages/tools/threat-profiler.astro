function computeScores(){
const raw={},maxP={};
THREATS.forEach(t=>{raw[t.id]=0;maxP[t.id]=0;});
QUESTIONS.forEach(q=>{
THREATS.forEach(t=>{
if(q.type==='radio'){maxP[t.id]+=q.options.reduce((m,o)=>Math.max(m,o.weights[t.id]||0),0);}
else{maxP[t.id]+=q.options.reduce((s,o)=>s+(o.weights[t.id]||0),0);}
});
});
QUESTIONS.forEach(q=>{
const ans=state.answers[q.id];
if(ans==null)return;
if(q.type==='radio'){const o=q.options[ans];if(o)THREATS.forEach(t=>{raw[t.id]+=(o.weights[t.id]||0);});}
else{(Array.isArray(ans)?ans:[]).forEach(i=>{const o=q.options[i];if(o)THREATS.forEach(t=>{raw[t.id]+=(o.weights[t.id]||0);});});}
});
const sc={};
THREATS.forEach(t=>{
const max=maxP[t.id]||1;
const pct=Math.min(100,Math.round((raw[t.id]/max)*100));
sc[t.id]={pct,level:pct>=75?'CRITICAL':pct>=50?'HIGH':pct>=25?'MODERATE':'LOW'};
});
return sc;
}
