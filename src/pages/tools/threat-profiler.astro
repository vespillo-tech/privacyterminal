---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Threat Model Calculator — Personal Risk Assessment | Privacy Terminal" description="Build your personalized privacy threat profile with 47 questions across 28 threat categories. Discover your risk level for surveillance, tracking, and data exposure. 100% client-side.">
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"SoftwareApplication","name":"Privacy Threat Model Calculator","applicationCategory":"SecurityApplication","operatingSystem":"Web Browser","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"description":"Build your personalized privacy threat profile with 47 questions across 28 threat categories. 100% client-side.","url":"https://privacyterminal.com/tools/threat-profiler/"}
</script>

  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type": "Question", "name": "What is a privacy threat model?", "acceptedAnswer": {"@type": "Answer", "text": "A threat model is a systematic assessment of which privacy and security threats are most relevant to your specific situation. It considers your online behavior, profession, location, devices, and relationships to identify where you are most vulnerable."}},
    {"@type": "Question", "name": "Is my data stored when I use this threat profiler?", "acceptedAnswer": {"@type": "Answer", "text": "No. All 47 questions are processed entirely in your browser. Zero data is transmitted to any server. Your answers exist only in browser memory and are discarded when you close the page."}},
    {"@type": "Question", "name": "How accurate is this threat assessment?", "acceptedAnswer": {"@type": "Answer", "text": "This tool analyzes 28 distinct threat categories using weighted scoring across 47 questions. It provides a useful starting point but is not a substitute for professional security audit. For high-risk individuals, consult EFF Surveillance Self-Defense and Access Now Digital Security Helpline."}}
  ]
}
</script>
  <div class="max-w-4xl mx-auto" id="threat-app">
    <div id="boot-screen" class="tui-box mb-8">
      <div class="tui-box-title">[ THREAT ANALYSIS ENGINE v0.1.0 ]</div>
      <div class="p-6 font-mono text-sm" id="boot-log">
        <div class="text-terminal-green">&gt; Initializing threat analysis engine...</div>
      </div>
    </div>
    <div id="wizard-container" style="display:none">
      <div class="tui-box mb-6">
        <div class="tui-box-title" id="step-title">[ STEP 1/10 ]</div>
        <div class="p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-terminal-cyan text-sm" id="step-label">IDENTITY &amp; PROFILE</span>
            <span class="text-terminal-muted text-xs" id="step-counter">1 / 10</span>
          </div>
          <div class="progress-bar"><div class="progress-fill" id="progress-fill" style="width:10%"></div></div>
          <div class="text-terminal-muted text-xs mt-2 font-mono" id="progress-blocks">&#x2588;&#x2588;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;&#x2591;</div>
        </div>
      </div>
      <div class="tui-box mb-6">
        <div class="tui-box-title" id="questions-box-title">[ ID &mdash; IDENTITY &amp; PROFILE ]</div>
        <div class="p-6" id="questions-container"></div>
      </div>
      <div class="flex justify-between items-center mb-8">
        <button class="btn-terminal" id="btn-back" onclick="wizardBack()" style="display:none">&larr; BACK</button>
        <div></div>
        <button class="btn-terminal" id="btn-next" onclick="wizardNext()">NEXT &rarr;</button>
      </div>
    </div>
    <div id="results-container" style="display:none"></div>
  </div>
</BaseLayout>

<script>
