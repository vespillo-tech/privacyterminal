const saved=Array.isArray(state.answers[q.id])?state.answers[q.id]:[];
q.options.forEach((opt,oi)=>{
const row=mkRow('c',q.id,oi,opt.label,saved.includes(oi),true);
row.addEventListener('click',()=>togMulti(q.id,oi,q.options.length));
d.appendChild(row);
});
const h=document.createElement('div');
h.className='text-terminal-muted text-xs mt-2 italic';
h.textContent='  (select all that apply)';
d.appendChild(h);
