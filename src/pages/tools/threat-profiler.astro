el('step-counter').textContent=(s+1)+' / '+total;
el('progress-fill').style.width=pct+'%';
el('progress-blocks').textContent='\u2588'.repeat(f)+'\u2591'.repeat(20-f);
el('questions-box-title').textContent='[ '+STEPS[s].icon+' - '+STEPS[s].label.toUpperCase()+' ]';
el('btn-back').style.display=s>0?'inline-block':'none';
