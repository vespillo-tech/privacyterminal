---
import ToolLayout from '../../layouts/ToolLayout.astro';
export const prerender = true;
---

<ToolLayout
  title="Metadata Stripper"
  toolName="metadata-stripper"
  toolVersion="1.0.0"
  description="Remove hidden EXIF data, GPS coordinates, camera info, and device identifiers from your photos before sharing. All processing happens in your browser — your images are never uploaded."
>
  <Fragment slot="controls">
    <div class="space-y-3">
      <!-- Drop zone -->
      <div
        id="drop-zone"
        class="border border-dashed border-terminal-border p-8 text-center cursor-pointer hover:border-terminal-cyan/50 transition-colors"
      >
        <div class="text-terminal-cyan text-2xl mb-2">◉</div>
        <p class="text-terminal-muted text-sm">Drop an image here or click to select</p>
        <p class="text-terminal-muted text-[10px] mt-1">JPEG, PNG, WebP — processed entirely in your browser</p>
        <input type="file" id="file-input" class="hidden" accept="image/jpeg,image/png,image/webp,image/tiff" />
      </div>

      <!-- Controls (hidden until image loaded) -->
      <div id="controls-row" class="hidden flex flex-wrap gap-2">
        <div class="flex items-center gap-2">
          <label class="text-terminal-muted text-xs">output:</label>
          <select id="output-format" class="bg-terminal-bg border border-terminal-border text-gray-300 text-xs p-1 focus:outline-none focus:border-terminal-green/50">
            <option value="image/jpeg">JPEG</option>
            <option value="image/png">PNG</option>
            <option value="image/webp">WebP</option>
          </select>
        </div>
        <div class="flex items-center gap-2" id="quality-row">
          <label class="text-terminal-muted text-xs">quality:</label>
          <input type="range" id="quality" min="50" max="100" value="92" class="w-24 accent-terminal-green" />
          <span id="quality-label" class="text-terminal-muted text-xs">92%</span>
        </div>
        <button id="btn-strip" class="px-4 py-2 border border-terminal-green text-terminal-green text-xs font-bold hover:bg-terminal-green/10 transition-colors">
          $ strip metadata
        </button>
        <button id="btn-download" class="hidden px-3 py-1.5 border border-terminal-cyan text-terminal-cyan text-xs hover:bg-terminal-cyan/10 transition-colors">
          $ download clean image
        </button>
        <button id="btn-reset" class="px-3 py-1.5 border border-terminal-border text-terminal-muted text-xs hover:text-terminal-red hover:border-terminal-red transition-colors">
          reset
        </button>
      </div>
    </div>
  </Fragment>

  <Fragment slot="results">
    <div id="results-container" class="hidden space-y-0">
      <!-- Before/After comparison -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        <div class="tui-box p-3">
          <span class="tui-box-title text-terminal-red">┤ ORIGINAL ├</span>
          <div class="mt-2">
            <div id="original-preview" class="flex justify-center items-center min-h-[120px] bg-black/30">
              <span class="text-terminal-muted text-xs">no image loaded</span>
            </div>
            <div id="original-info" class="mt-2 text-[10px] text-terminal-muted"></div>
          </div>
        </div>
        <div class="tui-box p-3">
          <span class="tui-box-title text-terminal-green">┤ CLEANED ├</span>
          <div class="mt-2">
            <div id="clean-preview" class="flex justify-center items-center min-h-[120px] bg-black/30">
              <span class="text-terminal-muted text-xs">strip metadata to see result</span>
            </div>
            <div id="clean-info" class="mt-2 text-[10px] text-terminal-muted"></div>
          </div>
        </div>
      </div>

      <!-- Metadata found -->
      <div id="metadata-panel" class="tui-box p-3">
        <span class="tui-box-title text-terminal-amber">┤ METADATA FOUND ├</span>
        <div id="metadata-content" class="mt-2 space-y-0.5 text-xs max-h-[300px] overflow-y-auto"></div>
      </div>

      <!-- GPS data (if found) -->
      <div id="gps-panel" class="tui-box p-3 hidden">
        <span class="tui-box-title text-terminal-red">┤ ⚠ GPS LOCATION FOUND ├</span>
        <div id="gps-content" class="mt-2 text-xs"></div>
      </div>
    </div>
  </Fragment>

  <!-- Educational section -->
  <div class="mt-6">
    <hr class="tui-hr" />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs text-terminal-muted py-3">
      <div>
        <span class="text-terminal-green font-bold">What metadata is hiding in your photos?</span>
        <p class="mt-1">Every photo you take embeds hidden data: your camera model, lens settings, exact GPS coordinates, date/time, software used, and sometimes even your name. This metadata travels with the image when you share it.</p>
      </div>
      <div>
        <span class="text-terminal-green font-bold">How does stripping work?</span>
        <p class="mt-1">We load your image onto an HTML Canvas element, which discards all metadata. Then we export a clean copy with only pixel data — no EXIF, no GPS, no camera info. The original image never leaves your browser.</p>
      </div>
    </div>
  </div>
</ToolLayout>

<script>
const PT = (window as any).privacyTerminal;

interface ExifTag {
  name: string;
  value: string;
  category: string;
  risk: 'high' | 'medium' | 'low';
}

// === EXIF PARSER (minimal, reads key JPEG EXIF tags) ===
function parseExif(buffer: ArrayBuffer): ExifTag[] {
  const tags: ExifTag[] = [];
  const view = new DataView(buffer);

  // Check for JPEG SOI marker
  if (view.getUint16(0) !== 0xFFD8) return tags;

  let offset = 2;
  while (offset < view.byteLength - 2) {
    const marker = view.getUint16(offset);
    if (marker === 0xFFE1) { // APP1 (EXIF)
      const length = view.getUint16(offset + 2);
      const exifData = new DataView(buffer, offset + 4, length - 2);
      parseExifData(exifData, tags);
      break;
    }
    if ((marker & 0xFF00) !== 0xFF00) break;
    const segLen = view.getUint16(offset + 2);
    offset += 2 + segLen;
  }

  // Also extract basic file info
  tags.push({ name: 'File Size', value: formatBytes(buffer.byteLength), category: 'File', risk: 'low' });

  return tags;
}

function parseExifData(data: DataView, tags: ExifTag[]): void {
  // Check "Exif\0\0" header
  const exifHeader = String.fromCharCode(data.getUint8(0), data.getUint8(1), data.getUint8(2), data.getUint8(3));
  if (exifHeader !== 'Exif') return;

  const tiffOffset = 6;
  const byteOrder = data.getUint16(tiffOffset);
  const isLE = byteOrder === 0x4949; // Little-endian (Intel)

  function getU16(off: number): number { return data.getUint16(tiffOffset + off, isLE); }
  function getU32(off: number): number { return data.getUint32(tiffOffset + off, isLE); }

  function readString(off: number, len: number): string {
    let s = '';
    for (let i = 0; i < len; i++) {
      const c = data.getUint8(tiffOffset + off + i);
      if (c === 0) break;
      s += String.fromCharCode(c);
    }
    return s.trim();
  }

  function readTagValue(tagType: number, count: number, valueOffset: number): string {
    if (tagType === 2) { // ASCII
      return count <= 4 ? readString(valueOffset - tiffOffset + 8, count) : readString(valueOffset, count);
    }
    if (tagType === 3) return String(getU16(valueOffset)); // SHORT
    if (tagType === 4) return String(getU32(valueOffset)); // LONG
    if (tagType === 5) { // RATIONAL
      const num = getU32(valueOffset);
      const den = getU32(valueOffset + 4);
      return den ? (num / den).toFixed(4) : String(num);
    }
    return '?';
  }

  const tagNames: Record<number, [string, string, ExifTag['risk']]> = {
    0x010F: ['Camera Make', 'Camera', 'medium'],
    0x0110: ['Camera Model', 'Camera', 'medium'],
    0x0131: ['Software', 'Software', 'medium'],
    0x0132: ['DateTime', 'Time', 'high'],
    0x013B: ['Artist', 'Personal', 'high'],
    0x8298: ['Copyright', 'Personal', 'medium'],
    0x8769: ['ExifIFD', 'Technical', 'low'],
    0x829A: ['Exposure Time', 'Camera', 'low'],
    0x829D: ['F-Number', 'Camera', 'low'],
    0x8827: ['ISO Speed', 'Camera', 'low'],
    0x9003: ['Date Original', 'Time', 'high'],
    0x9004: ['Date Digitized', 'Time', 'high'],
    0xA002: ['Image Width', 'Image', 'low'],
    0xA003: ['Image Height', 'Image', 'low'],
    0xA420: ['Unique Image ID', 'Identifier', 'high'],
    0x0112: ['Orientation', 'Image', 'low'],
    0x011A: ['X Resolution', 'Image', 'low'],
    0x011B: ['Y Resolution', 'Image', 'low'],
  };

  const gpsTagNames: Record<number, string> = {
    0x0001: 'GPS Lat Ref', 0x0002: 'GPS Latitude', 0x0003: 'GPS Lon Ref',
    0x0004: 'GPS Longitude', 0x0005: 'GPS Alt Ref', 0x0006: 'GPS Altitude',
    0x001D: 'GPS Date',
  };

  try {
    const ifdOffset = getU32(4);
    const numEntries = getU16(ifdOffset);

    let gpsIFDOffset = 0;
    let exifIFDOffset = 0;

    for (let i = 0; i < Math.min(numEntries, 50); i++) {
      const entryOffset = ifdOffset + 2 + i * 12;
      const tagId = getU16(entryOffset);
      const tagType = getU16(entryOffset + 2);
      const count = getU32(entryOffset + 4);
      const valueOffset = count * [0, 1, 1, 2, 4, 8, 1, 1, 2, 4, 8, 4, 8][tagType] > 4
        ? getU32(entryOffset + 8) : (entryOffset + 8 - tiffOffset);

      if (tagId === 0x8825) { gpsIFDOffset = getU32(entryOffset + 8); continue; }
      if (tagId === 0x8769) { exifIFDOffset = getU32(entryOffset + 8); continue; }

      const info = tagNames[tagId];
      if (info) {
        try {
          const val = readTagValue(tagType, count, valueOffset);
          if (val && val !== '?') tags.push({ name: info[0], value: val, category: info[1], risk: info[2] });
        } catch {}
      }
    }

    // Parse EXIF sub-IFD
    if (exifIFDOffset) {
      try {
        const numExif = getU16(exifIFDOffset);
        for (let i = 0; i < Math.min(numExif, 50); i++) {
          const entryOffset = exifIFDOffset + 2 + i * 12;
          const tagId = getU16(entryOffset);
          const tagType = getU16(entryOffset + 2);
          const count = getU32(entryOffset + 4);
          const valueOffset = count * [0, 1, 1, 2, 4, 8, 1, 1, 2, 4, 8, 4, 8][tagType] > 4
            ? getU32(entryOffset + 8) : (entryOffset + 8 - tiffOffset);
          const info = tagNames[tagId];
          if (info) {
            try {
              const val = readTagValue(tagType, count, valueOffset);
              if (val && val !== '?') tags.push({ name: info[0], value: val, category: info[1], risk: info[2] });
            } catch {}
          }
        }
      } catch {}
    }

    // Parse GPS IFD
    if (gpsIFDOffset) {
      try {
        const numGps = getU16(gpsIFDOffset);
        for (let i = 0; i < Math.min(numGps, 20); i++) {
          const entryOffset = gpsIFDOffset + 2 + i * 12;
          const tagId = getU16(entryOffset);
          const tagType = getU16(entryOffset + 2);
          const count = getU32(entryOffset + 4);
          const valueOffset = count * [0, 1, 1, 2, 4, 8, 1, 1, 2, 4, 8, 4, 8][tagType] > 4
            ? getU32(entryOffset + 8) : (entryOffset + 8 - tiffOffset);
          const name = gpsTagNames[tagId];
          if (name) {
            try {
              let val: string;
              if (tagType === 5 && count === 3) {
                // Rational GPS coordinates (degrees, minutes, seconds)
                const d = getU32(valueOffset) / getU32(valueOffset + 4);
                const m = getU32(valueOffset + 8) / getU32(valueOffset + 12);
                const s = getU32(valueOffset + 16) / getU32(valueOffset + 20);
                val = `${d}° ${m}' ${s.toFixed(2)}"`;
              } else {
                val = readTagValue(tagType, count, valueOffset);
              }
              if (val && val !== '?') tags.push({ name, value: val, category: 'GPS', risk: 'high' });
            } catch {}
          }
        }
      } catch {}
    }
  } catch {}
}

function formatBytes(b: number): string {
  if (b < 1024) return b + ' B';
  if (b < 1024 * 1024) return (b / 1024).toFixed(1) + ' KB';
  return (b / (1024 * 1024)).toFixed(1) + ' MB';
}

// === STATE ===
let originalFile: File | null = null;
let originalBuffer: ArrayBuffer | null = null;
let cleanBlob: Blob | null = null;

// === FILE HANDLING ===
const dropZone = document.getElementById('drop-zone')!;
const fileInput = document.getElementById('file-input') as HTMLInputElement;

dropZone.addEventListener('click', () => fileInput.click());
dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-terminal-cyan'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-terminal-cyan'));
dropZone.addEventListener('drop', (e) => { e.preventDefault(); dropZone.classList.remove('border-terminal-cyan'); if (e.dataTransfer?.files[0]) loadImage(e.dataTransfer.files[0]); });
fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadImage(fileInput.files[0]); });

async function loadImage(file: File) {
  if (!file.type.startsWith('image/')) { PT?.appendLog('Not an image file', 'error'); return; }
  originalFile = file;
  originalBuffer = await file.arrayBuffer();

  PT?.appendLog(`Loaded: ${file.name} (${formatBytes(file.size)})`, 'info');

  // Show controls
  document.getElementById('controls-row')!.classList.remove('hidden');
  document.getElementById('results-container')!.classList.remove('hidden');
  document.getElementById('btn-download')!.classList.add('hidden');

  // Show original preview
  const url = URL.createObjectURL(file);
  const img = new Image();
  img.onload = () => {
    document.getElementById('original-preview')!.innerHTML = `<img src="${url}" class="max-h-[200px] max-w-full object-contain" />`;
    document.getElementById('original-info')!.textContent = `${img.naturalWidth}×${img.naturalHeight} · ${file.type} · ${formatBytes(file.size)}`;
    PT?.appendLog(`Image: ${img.naturalWidth}×${img.naturalHeight}, ${file.type}`, 'info');
  };
  img.src = url;

  // Parse and display EXIF
  PT?.appendLog('Parsing metadata...', 'info');
  const exifTags = parseExif(originalBuffer);

  const metaEl = document.getElementById('metadata-content')!;
  if (exifTags.length > 1) { // >1 because file size is always there
    metaEl.innerHTML = exifTags.map(t => `
      <div class="flex items-center justify-between py-0.5 border-b border-terminal-border/20">
        <span class="text-terminal-muted">${t.name}</span>
        <div class="flex items-center gap-2">
          <span class="text-gray-300 font-mono text-[10px]">${t.value}</span>
          <span class="${t.risk === 'high' ? 'text-terminal-red' : t.risk === 'medium' ? 'text-terminal-amber' : 'text-terminal-green'} text-[10px]">[${t.risk.toUpperCase()}]</span>
        </div>
      </div>
    `).join('');
    PT?.appendLog(`Found ${exifTags.length} metadata fields`, 'warn');
  } else {
    metaEl.innerHTML = '<div class="text-terminal-green">No significant EXIF metadata found in this image.</div>';
    PT?.appendLog('No significant EXIF metadata found', 'success');
  }

  // GPS warning
  const gpsPanel = document.getElementById('gps-panel')!;
  const gpsTags = exifTags.filter(t => t.category === 'GPS');
  if (gpsTags.length > 0) {
    gpsPanel.classList.remove('hidden');
    document.getElementById('gps-content')!.innerHTML = `
      <div class="text-terminal-red font-bold mb-2">⚠ This image contains GPS coordinates!</div>
      <div class="space-y-0.5">
        ${gpsTags.map(t => `<div><span class="text-terminal-muted">${t.name}:</span> <span class="text-terminal-red font-mono">${t.value}</span></div>`).join('')}
      </div>
      <div class="text-terminal-muted mt-2">Sharing this image could reveal your exact location.</div>
    `;
    PT?.appendLog('⚠ GPS LOCATION DATA FOUND — strip metadata to remove!', 'error');
  } else {
    gpsPanel.classList.add('hidden');
  }

  // Set output format based on input
  const fmt = document.getElementById('output-format') as HTMLSelectElement;
  if (file.type === 'image/png') fmt.value = 'image/png';
  else if (file.type === 'image/webp') fmt.value = 'image/webp';
  else fmt.value = 'image/jpeg';
  updateQualityVisibility();
}

// === STRIP METADATA ===
document.getElementById('btn-strip')!.addEventListener('click', async () => {
  if (!originalFile) { PT?.appendLog('No image loaded', 'warn'); return; }

  PT?.setToolStatus('running');
  PT?.appendLog('Stripping metadata via Canvas re-encoding...', 'info');

  const format = (document.getElementById('output-format') as HTMLSelectElement).value;
  const quality = parseInt((document.getElementById('quality') as HTMLInputElement).value) / 100;

  const url = URL.createObjectURL(originalFile);
  const img = new Image();
  img.src = url;
  await new Promise(r => img.onload = r);

  const canvas = document.createElement('canvas');
  canvas.width = img.naturalWidth;
  canvas.height = img.naturalHeight;
  const ctx = canvas.getContext('2d')!;
  ctx.drawImage(img, 0, 0);

  const blob = await new Promise<Blob | null>(r => canvas.toBlob(r, format, quality));
  URL.revokeObjectURL(url);

  if (!blob) { PT?.appendLog('Failed to create clean image', 'error'); PT?.setToolStatus('error'); return; }

  cleanBlob = blob;

  // Show clean preview
  const cleanUrl = URL.createObjectURL(blob);
  document.getElementById('clean-preview')!.innerHTML = `<img src="${cleanUrl}" class="max-h-[200px] max-w-full object-contain" />`;
  document.getElementById('clean-info')!.textContent = `${img.naturalWidth}×${img.naturalHeight} · ${format} · ${formatBytes(blob.size)}`;

  const savings = originalFile.size - blob.size;
  const pct = ((savings / originalFile.size) * 100).toFixed(1);

  PT?.appendLog(`Clean image: ${formatBytes(blob.size)} (${savings > 0 ? '-' : '+'}${formatBytes(Math.abs(savings))}, ${pct}%)`, 'success');
  PT?.appendLog('All EXIF, GPS, camera, and device metadata removed', 'success');

  document.getElementById('btn-download')!.classList.remove('hidden');
  PT?.setToolStatus('complete');

  // Track tool usage for gamification
  try {
    const { trackTool } = await import('../../scripts/privacy-score');
    await trackTool('metadata-stripper');
  } catch { /* gamification optional */ }
});

// === DOWNLOAD ===
document.getElementById('btn-download')!.addEventListener('click', () => {
  if (!cleanBlob || !originalFile) return;
  const ext = (document.getElementById('output-format') as HTMLSelectElement).value.split('/')[1];
  const name = originalFile.name.replace(/\.[^.]+$/, '') + `-clean.${ext}`;
  const a = document.createElement('a');
  a.href = URL.createObjectURL(cleanBlob);
  a.download = name;
  a.click();
  PT?.appendLog(`Downloaded: ${name}`, 'success');
});

// === RESET ===
document.getElementById('btn-reset')!.addEventListener('click', () => {
  originalFile = null; originalBuffer = null; cleanBlob = null;
  document.getElementById('controls-row')!.classList.add('hidden');
  document.getElementById('results-container')!.classList.add('hidden');
  document.getElementById('btn-download')!.classList.add('hidden');
  document.getElementById('original-preview')!.innerHTML = '<span class="text-terminal-muted text-xs">no image loaded</span>';
  document.getElementById('clean-preview')!.innerHTML = '<span class="text-terminal-muted text-xs">strip metadata to see result</span>';
  document.getElementById('original-info')!.textContent = '';
  document.getElementById('clean-info')!.textContent = '';
  PT?.appendLog('Reset', 'info');
  PT?.setToolStatus('ready');
});

// === QUALITY SLIDER ===
const qualitySlider = document.getElementById('quality') as HTMLInputElement;
const qualityLabel = document.getElementById('quality-label')!;
qualitySlider.addEventListener('input', () => { qualityLabel.textContent = qualitySlider.value + '%'; });

function updateQualityVisibility() {
  const fmt = (document.getElementById('output-format') as HTMLSelectElement).value;
  document.getElementById('quality-row')!.style.display = fmt === 'image/png' ? 'none' : 'flex';
}
document.getElementById('output-format')!.addEventListener('change', updateQualityVisibility);
</script>
