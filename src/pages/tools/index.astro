---
import BaseLayout from '../../layouts/BaseLayout.astro';
export const prerender = true;

const tools = [
  { name: 'threat-profiler', title: 'Threat Model Profiler', desc: 'Answer 48 questions, get a personalized threat profile across 28 attack categories. 100% client-side.', status: 'ready' },
  { name: 'hash-generator', title: 'Hash Generator & Verifier', desc: 'SHA-256, SHA-512, SHA-384, SHA-1, MD5 — all client-side via Web Crypto API.', status: 'ready' },
  { name: 'fingerprint-analyzer', title: 'Browser Fingerprint Analyzer', desc: 'Canvas, WebGL, AudioContext, fonts, screen, timezone, hardware — 30+ vectors.', status: 'ready' },
  { name: 'leak-tester', title: 'IP & DNS Leak Tester', desc: 'Verify your VPN. Detect IP exposure, DNS leaks, WebRTC disclosure.', status: 'soon' },
  { name: 'webrtc-detector', title: 'WebRTC Leak Detector', desc: 'Test whether WebRTC exposes your real IP behind VPN or proxy.', status: 'soon' },
  { name: 'metadata-stripper', title: 'Metadata Stripper', desc: 'Remove EXIF, GPS, camera info from photos. Client-side processing.', status: 'soon' },
  { name: 'email-header-analyzer', title: 'Email Header Analyzer', desc: 'Parse Received headers, verify SPF/DKIM/DMARC, detect spoofing.', status: 'soon' },
];
---

<BaseLayout title="Free Online Privacy Tools — Browser-Based, Zero Tracking | Privacy Terminal" description="Open-source privacy tools that run entirely in your browser. Hash generators, threat modeling, and more. No data transmitted, no tracking, no cookies." statusLeft="tools index" statusRight={`${tools.filter(t=>t.status==='ready').length}/${tools.length} ready`}>
  <div class="mb-4">
    <div class="text-terminal-green text-glow-green font-bold mb-1">~/tools</div>
    <div class="text-terminal-muted text-xs">Every tool runs in your browser. Your data never leaves your machine.</div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-0">
    {tools.map((tool) => {
      const isReady = tool.status === 'ready';
      return (
        <div class:list={['tui-box p-3 relative', !isReady && 'opacity-60']}>
          <span class:list={['tui-box-title', isReady ? 'text-terminal-green' : 'text-terminal-muted']}>
            ┤ {isReady ? 'READY' : 'SOON'} ├
          </span>
          <div class="mt-1">
            {isReady ? (
              <a href={`/tools/${tool.name}`} class="text-terminal-green font-bold text-sm hover:text-glow-green no-underline">
                {tool.title}
              </a>
            ) : (
              <span class="text-terminal-muted font-bold text-sm">{tool.title}</span>
            )}
            <p class="text-terminal-muted text-xs mt-1 leading-relaxed">{tool.desc}</p>
            {isReady && (
              <div class="mt-2">
                <a href={`/tools/${tool.name}`} class="text-terminal-green text-xs hover:text-glow-green">$ run →</a>
              </div>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <hr class="tui-hr" />
  <div class="text-xs text-terminal-muted py-2">
    <span class="text-terminal-green">[NOTE]</span> All tools use standard Web APIs. Source code is public. Zero data leaves your browser.
  </div>
</BaseLayout>
