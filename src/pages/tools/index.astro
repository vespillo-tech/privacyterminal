---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  {
    name: 'fingerprint-analyzer',
    title: 'Browser Fingerprint Analyzer',
    description: 'See exactly how websites identify you. Tests 30+ tracking vectors including canvas, WebGL, audio fingerprinting, font enumeration, and hardware profiling.',
    icon: '⬡',
    color: 'terminal-green',
    status: 'coming-soon',
  },
  {
    name: 'leak-tester',
    title: 'IP & DNS Leak Tester',
    description: 'Verify your VPN isn\'t leaking. Detects IP exposure, DNS leaks, and WebRTC IP disclosure.',
    icon: '◈',
    color: 'terminal-cyan',
    status: 'coming-soon',
  },
  {
    name: 'webrtc-detector',
    title: 'WebRTC Leak Detector',
    description: 'Test whether WebRTC is exposing your real IP address behind VPN or proxy connections.',
    icon: '◇',
    color: 'terminal-cyan',
    status: 'coming-soon',
  },
  {
    name: 'hash-generator',
    title: 'Hash Generator & Verifier',
    description: 'Generate and verify cryptographic hashes. MD5, SHA-1, SHA-256, SHA-512 — all computed client-side using Web Crypto API.',
    icon: '⬢',
    color: 'terminal-red',
    status: 'coming-soon',
  },
  {
    name: 'metadata-stripper',
    title: 'Metadata Stripper',
    description: 'Remove hidden EXIF data, GPS coordinates, camera info, and device identifiers from your photos before sharing.',
    icon: '◉',
    color: 'terminal-amber',
    status: 'coming-soon',
  },
  {
    name: 'email-header-analyzer',
    title: 'Email Header Analyzer',
    description: 'Parse email headers to trace message routes, verify SPF/DKIM/DMARC authentication, and identify potential spoofing.',
    icon: '◎',
    color: 'terminal-amber',
    status: 'coming-soon',
  },
];
---

<BaseLayout title="Privacy Tools — Privacy Terminal" description="Open-source browser-based privacy tools. Fingerprint analyzer, leak tester, metadata stripper, and more. All client-side, no data transmitted.">
  <div class="mb-8">
    <h1 class="text-terminal-green text-glow-green text-lg font-bold mb-2">
      <span class="text-terminal-muted">~/</span>tools
    </h1>
    <p class="text-terminal-muted text-sm leading-relaxed">
      Every tool runs entirely in your browser. Your data never leaves your machine.
      No accounts required. No tracking. Verify in our
      <a href="https://github.com/vespillo-tech/privacyterminal" class="text-terminal-cyan hover:text-terminal-green">source code</a>.
    </p>
  </div>

  <!-- Boot sequence -->
  <div class="space-y-1 mb-8 text-xs">
    <div class="text-terminal-muted">
      <span class="text-terminal-green">[SCAN]</span> Enumerating available modules...
    </div>
    <div class="text-terminal-muted">
      <span class="text-terminal-cyan">[INFO]</span> Found {tools.length} tools
    </div>
    <div class="text-terminal-muted">
      <span class="text-terminal-green">[READY]</span> Tool index loaded
    </div>
  </div>

  <!-- Tool grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
    {tools.map((tool) => {
      const isReady = tool.status === 'ready';
      const href = isReady ? `/tools/${tool.name}` : '#';
      return (
        <div
          class:list={[
            'group block border border-terminal-border rounded p-5 transition-all',
            isReady
              ? 'hover:border-terminal-green/50 hover:bg-terminal-green/5'
              : 'opacity-75',
          ]}
        >
          <div class="flex items-start gap-3">
            <span class={`text-${tool.color} text-xl leading-none mt-0.5`}>{tool.icon}</span>
            <div class="flex-1">
              <div class="flex items-center justify-between gap-2 mb-1.5">
                <h2 class={`text-${tool.color} text-sm font-bold`}>{tool.title}</h2>
                <span class={`text-[10px] ${isReady ? 'text-terminal-green' : 'text-terminal-amber'}`}>
                  [{isReady ? 'READY' : 'COMING SOON'}]
                </span>
              </div>
              <p class="text-terminal-muted text-xs leading-relaxed">{tool.description}</p>
            </div>
          </div>
          {isReady && (
            <div class="text-right mt-2">
              <a href={href} class="text-terminal-green text-xs no-underline">
                $ run →
              </a>
            </div>
          )}
        </div>
      );
    })}
  </div>

  <!-- Privacy note -->
  <div class="border-t border-terminal-border pt-6 text-xs text-terminal-muted">
    <span class="text-terminal-green">[NOTE]</span> All tools use standard Web APIs (Canvas, WebGL, Web Crypto, etc.).
    Source code is public. We encourage you to inspect it before use.
    Zero data leaves your browser — verify via your browser's Network tab.
  </div>
</BaseLayout>
