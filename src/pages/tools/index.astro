---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
export const prerender = true;

const allTools = await getCollection('tools');
const tools = allTools
  .sort((a, b) => a.data.order - b.data.order)
  .map(t => ({
    name: t.id,
    title: t.data.title,
    desc: t.data.description,
    status: t.data.status,
  }));
---

<BaseLayout title="Free Online Privacy Tools — Browser-Based, Zero Analytics | Privacy Terminal" description="Open-source privacy tools that run entirely in your browser. Hash generators, threat modeling, and more. Zero analytics, zero cookies, zero tracking of any kind." statusLeft="tools index" statusRight={`${tools.filter(t=>t.status==='ready').length}/${tools.length} ready`}>
  <div class="mb-4">
    <h1 class="text-terminal-green text-glow-green font-bold mb-1 text-base">~/tools</h1>
    <div class="text-terminal-muted text-xs">Every tool runs in your browser. Your data never leaves your machine.</div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-0">
    {tools.map((tool) => {
      const isReady = tool.status === 'ready';
      return (
        <div class:list={['tui-box p-3 relative', !isReady && 'opacity-60']}>
          <span class:list={['tui-box-title', isReady ? 'text-terminal-green' : 'text-terminal-muted']}>
            ├ {isReady ? 'READY' : 'SOON'} ┤
          </span>
          <div class="mt-1">
            {isReady ? (
              <a href={`/tools/${tool.name}`} class="text-terminal-green font-bold text-sm hover:text-glow-green no-underline">
                {tool.title}
              </a>
            ) : (
              <span class="text-terminal-muted font-bold text-sm">{tool.title}</span>
            )}
            <p class="text-terminal-muted text-xs mt-1 leading-relaxed">{tool.desc}</p>
            {isReady && (
              <div class="mt-2">
                <a href={`/tools/${tool.name}`} class="text-terminal-green text-xs hover:text-glow-green">$ run →</a>
              </div>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <hr class="tui-hr" />
  <div class="text-xs text-terminal-muted py-2">
    <span class="text-terminal-green">[NOTE]</span> All tools use standard Web APIs. Source code is public. Zero data leaves your browser.
  </div>
</BaseLayout>
