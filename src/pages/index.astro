---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout title="Privacy Terminal — Open Source Privacy Tools & Education" statusLeft="system ready" statusRight="6 tools │ 13 guides">
  <!-- SVG Logo with terminal CRT effects -->
  <div class="logo-container py-4 md:py-8 flex justify-center px-4">
    <div class="logo-wrapper">
      <img src="/images/logo.svg" alt="Privacy Terminal" class="logo-img w-full max-w-3xl" />
    </div>
  </div>

  <style>
    .logo-wrapper {
      position: relative;
      display: inline-block;
      width: 100%;
      max-width: 48rem;
      /* Boot animation on wrapper — plays exactly once */
      animation: logoReveal 1.2s ease-out forwards;
    }

    .logo-img {
      filter:
        drop-shadow(0 0 2px rgba(0, 255, 65, 0.6))
        drop-shadow(0 0 8px rgba(0, 255, 65, 0.25));
      animation: phosphorPulse 5s ease-in-out infinite;
    }

    /* Phosphor glow breathing */
    @keyframes phosphorPulse {
      0%, 100% {
        filter:
          drop-shadow(0 0 2px rgba(0, 255, 65, 0.6))
          drop-shadow(0 0 8px rgba(0, 255, 65, 0.25));
      }
      50% {
        filter:
          drop-shadow(0 0 3px rgba(0, 255, 65, 0.7))
          drop-shadow(0 0 10px rgba(0, 255, 65, 0.3));
      }
    }

    /* Boot-up reveal on wrapper — one-shot */
    @keyframes logoReveal {
      0% {
        opacity: 0;
        transform: scaleY(0.01);
      }
      30% {
        opacity: 1;
        transform: scaleY(0.01);
      }
      50% {
        transform: scaleY(1.02) scaleX(0.99);
      }
      70% {
        transform: scaleY(1) scaleX(1);
      }
      100% {
        opacity: 1;
        transform: scaleY(1) scaleX(1);
      }
    }

    /* Brighten slightly on hover */
    .logo-wrapper:hover .logo-img {
      filter:
        drop-shadow(0 0 3px rgba(0, 255, 65, 0.7))
        drop-shadow(0 0 12px rgba(0, 255, 65, 0.35));
      transition: filter 0.3s ease;
    }

    /* Reduce motion for accessibility */
    @media (prefers-reduced-motion: reduce) {
      .logo-wrapper {
        animation: none;
        opacity: 1;
      }
      .logo-img {
        animation: none;
        filter:
          drop-shadow(0 0 2px rgba(0, 255, 65, 0.6))
          drop-shadow(0 0 8px rgba(0, 255, 65, 0.25));
      }
    }
  </style>

  <!-- Boot sequence -->
  <div class="space-y-1 mb-4 text-xs px-2">
    <div class="text-terminal-muted"><span class="text-terminal-green">[BOOT]</span> Privacy Terminal v0.1.0</div>
    <div class="text-terminal-muted"><span class="text-terminal-cyan">[INFO]</span> No tracking · No cookies · No external requests</div>
    <div class="text-terminal-muted"><span class="text-terminal-green">[READY]</span> All tools run client-side. Your data never leaves your browser.</div>
    <div class="mt-2"><span class="text-terminal-green">$</span> <span class="text-white">Welcome to Privacy Terminal</span><span class="cursor-blink"></span></div>
  </div>

  <hr class="tui-hr" />

  <!-- Dual panel layout: TOOLS + GUIDES -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 lg:gap-0">

    <!-- TOOLS PANEL -->
    <div class="tui-box p-3 lg:border-r-0">
      <span class="tui-box-title text-terminal-green">┤ TOOLS ├</span>
      <div class="space-y-2 mt-2">
        <a href="/tools/hash-generator" class="flex items-center justify-between py-1 px-2 hover:bg-terminal-green/5 transition-colors group">
          <div class="flex items-center gap-2">
            <span class="text-terminal-green">│</span>
            <span class="text-gray-300 group-hover:text-terminal-green">Hash Generator & Verifier</span>
          </div>
          <span class="text-terminal-green text-xs">[READY]</span>
        </a>
        <div class="flex items-center justify-between py-1 px-2 opacity-60">
          <div class="flex items-center gap-2">
            <span class="text-terminal-muted">│</span>
            <span class="text-terminal-muted">Browser Fingerprint Analyzer</span>
          </div>
          <span class="text-terminal-amber text-xs">[SOON]</span>
        </div>
        <div class="flex items-center justify-between py-1 px-2 opacity-60">
          <div class="flex items-center gap-2">
            <span class="text-terminal-muted">│</span>
            <span class="text-terminal-muted">IP & DNS Leak Tester</span>
          </div>
          <span class="text-terminal-amber text-xs">[SOON]</span>
        </div>
        <div class="flex items-center justify-between py-1 px-2 opacity-60">
          <div class="flex items-center gap-2">
            <span class="text-terminal-muted">│</span>
            <span class="text-terminal-muted">WebRTC Leak Detector</span>
          </div>
          <span class="text-terminal-amber text-xs">[SOON]</span>
        </div>
        <div class="flex items-center justify-between py-1 px-2 opacity-60">
          <div class="flex items-center gap-2">
            <span class="text-terminal-muted">│</span>
            <span class="text-terminal-muted">Metadata Stripper</span>
          </div>
          <span class="text-terminal-amber text-xs">[SOON]</span>
        </div>
        <div class="flex items-center justify-between py-1 px-2 opacity-60">
          <div class="flex items-center gap-2">
            <span class="text-terminal-muted">│</span>
            <span class="text-terminal-muted">Email Header Analyzer</span>
          </div>
          <span class="text-terminal-amber text-xs">[SOON]</span>
        </div>
        <div class="text-center py-2">
          <a href="/tools" class="text-terminal-cyan text-xs hover:text-terminal-green">$ ls ./tools →</a>
        </div>
      </div>
    </div>

    <!-- GUIDES PANEL -->
    <div class="tui-box p-3">
      <span class="tui-box-title text-terminal-cyan">┤ GUIDES ├</span>
      <div class="space-y-3 mt-2">
        <!-- Foundations -->
        <div>
          <div class="text-terminal-green text-xs font-bold mb-1 px-2">foundations/</div>
          <a href="/guides/how-youre-being-tracked" class="flex items-center gap-2 py-0.5 px-2 hover:bg-terminal-green/5 transition-colors group">
            <span class="text-terminal-green">├─</span>
            <span class="text-gray-300 group-hover:text-terminal-green text-xs">How You're Being Tracked Right Now</span>
          </a>
          <a href="/guides/who-wants-your-data" class="flex items-center gap-2 py-0.5 px-2 hover:bg-terminal-green/5 transition-colors group">
            <span class="text-terminal-green">├─</span>
            <span class="text-gray-300 group-hover:text-terminal-green text-xs">Who Wants Your Data and Why</span>
          </a>
          <a href="/guides/the-5-minute-privacy-checkup" class="flex items-center gap-2 py-0.5 px-2 hover:bg-terminal-green/5 transition-colors group">
            <span class="text-terminal-green">├─</span>
            <span class="text-gray-300 group-hover:text-terminal-green text-xs">The 5-Minute Privacy Checkup</span>
          </a>
          <a href="/guides/browser-fingerprinting-explained" class="flex items-center gap-2 py-0.5 px-2 hover:bg-terminal-green/5 transition-colors group">
            <span class="text-terminal-green">└─</span>
            <span class="text-gray-300 group-hover:text-terminal-green text-xs">Browser Fingerprinting Explained</span>
          </a>
        </div>
        <!-- Essentials -->
        <div>
          <div class="text-terminal-cyan text-xs font-bold mb-1 px-2">essentials/</div>
          <div class="flex items-center gap-2 py-0.5 px-2 opacity-60">
            <span class="text-terminal-muted">└─</span>
            <span class="text-terminal-muted text-xs">3 guides planned</span>
          </div>
        </div>
        <!-- Intermediate + Advanced -->
        <div>
          <div class="text-terminal-amber text-xs font-bold mb-1 px-2">intermediate/ + advanced/</div>
          <div class="flex items-center gap-2 py-0.5 px-2 opacity-60">
            <span class="text-terminal-muted">└─</span>
            <span class="text-terminal-muted text-xs">5 guides planned</span>
          </div>
        </div>
        <div class="text-center py-2">
          <a href="/guides" class="text-terminal-cyan text-xs hover:text-terminal-green">$ ls ./guides →</a>
        </div>
      </div>
    </div>
  </div>

  <hr class="tui-hr" />

  <!-- Promise row -->
  <div class="grid grid-cols-3 gap-0 text-xs text-center py-3">
    <div class="px-2">
      <div class="text-terminal-green font-bold mb-1">⊘ ZERO TRACKING</div>
      <div class="text-terminal-muted">No analytics. No fingerprinting. No cookies.</div>
    </div>
    <div class="px-2 border-x border-terminal-border">
      <div class="text-terminal-cyan font-bold mb-1">⊚ CLIENT-SIDE</div>
      <div class="text-terminal-muted">Your data never leaves your browser.</div>
    </div>
    <div class="px-2">
      <div class="text-terminal-amber font-bold mb-1">⊡ OPEN SOURCE</div>
      <div class="text-terminal-muted">Every line of code is public. Verify.</div>
    </div>
  </div>
</BaseLayout>
