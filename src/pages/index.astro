---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;

// Load homepage singleton
const homepageEntry = await getEntry('site', 'homepage');
const hp = homepageEntry?.data as {
  hero_cards: Array<{ box_title: string; title_color: string; heading: string; description: string; cta_text: string; link: string }>;
  boot_messages: Array<{ type: string; text: string }>;
  promises: Array<{ icon: string; title: string; color: string; description: string }>;
  social_proof: string;
};

// Load tools for the tools panel (ready tools only, sorted by order)
const allTools = await getCollection('tools');
const readyTools = allTools
  .filter(t => t.data.status === 'ready')
  .sort((a, b) => a.data.order - b.data.order);
const soonCount = allTools.length - readyTools.length;

// Map title_color to Tailwind classes
const colorClass: Record<string, string> = {
  green: 'text-terminal-green',
  cyan:  'text-terminal-cyan',
  amber: 'text-terminal-amber',
};
const hoverClass: Record<string, string> = {
  green: 'group-hover:text-terminal-green',
  cyan:  'group-hover:text-terminal-cyan',
  amber: 'group-hover:text-terminal-amber',
};
---
<BaseLayout title="Free Privacy Tools & Guides — Protect Your Digital Privacy | Privacy Terminal" description="Free open-source privacy tools that run in your browser. Check your threat model, analyze your fingerprint, and learn to protect your digital identity. Zero tracking." statusLeft="system ready" statusRight="3 tools │ 8 guides">
  <!-- SVG Logo with terminal CRT effects -->
  <div class="logo-container py-4 md:py-8 flex justify-center px-4">
    <div class="logo-wrapper">
      <img src="/images/logo.svg" alt="Privacy Terminal" class="logo-img w-full max-w-3xl" />
    </div>
  </div>

  <style>
    .logo-wrapper {
      position: relative;
      display: inline-block;
      width: 100%;
      max-width: 48rem;
      animation: logoReveal 1.2s ease-out forwards;
    }
    .logo-img {
      filter:
        drop-shadow(0 0 2px rgba(0, 255, 65, 0.6))
        drop-shadow(0 0 8px rgba(0, 255, 65, 0.25));
      animation: phosphorPulse 5s ease-in-out infinite;
    }
    @keyframes phosphorPulse {
      0%, 100% {
        filter:
          drop-shadow(0 0 2px rgba(0, 255, 65, 0.6))
          drop-shadow(0 0 8px rgba(0, 255, 65, 0.25));
      }
      50% {
        filter:
          drop-shadow(0 0 3px rgba(0, 255, 65, 0.7))
          drop-shadow(0 0 10px rgba(0, 255, 65, 0.3));
      }
    }
    @keyframes logoReveal {
      0% { opacity: 0; transform: scaleY(0.01); }
      30% { opacity: 1; transform: scaleY(0.01); }
      50% { transform: scaleY(1.02) scaleX(0.99); }
      70% { transform: scaleY(1) scaleX(1); }
      100% { opacity: 1; transform: scaleY(1) scaleX(1); }
    }
    .logo-wrapper:hover .logo-img {
      filter:
        drop-shadow(0 0 3px rgba(0, 255, 65, 0.7))
        drop-shadow(0 0 12px rgba(0, 255, 65, 0.35));
      transition: filter 0.3s ease;
    }
    @media (prefers-reduced-motion: reduce) {
      .logo-wrapper { animation: none; opacity: 1; }
      .logo-img {
        animation: none;
        filter:
          drop-shadow(0 0 2px rgba(0, 255, 65, 0.6))
          drop-shadow(0 0 8px rgba(0, 255, 65, 0.25));
      }
    }
  </style>
  <!-- Boot sequence -->
  <div id="boot-sequence" class="space-y-1 mb-2 text-xs px-2">
    {hp.boot_messages.map((msg, i) => (
      <div class="boot-line" data-delay={i}>
        <span class:list={[
          msg.type === 'BOOT'  ? 'text-terminal-green' : '',
          msg.type === 'INFO'  ? 'text-terminal-cyan'  : '',
          msg.type === 'READY' ? 'text-terminal-green' : '',
        ]}>[{msg.type}]</span>
        {' '}
        <span class="text-terminal-muted">{msg.text}</span>
      </div>
    ))}
  </div>

  <!-- Welcome prompt -->
  <div class="mb-4 px-2">
    <span class="text-terminal-green">$</span> <span class="text-white text-sm">Welcome to Privacy Terminal</span><span class="cursor-blink"></span>
  </div>

  <!-- THREE CLEAR PATHS -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-0 mb-4">
    {hp.hero_cards.map((card) => (
      <a href={card.link} class="tui-box p-4 hover:bg-terminal-green/5 transition-colors group block no-underline">
        <span class:list={['tui-box-title', colorClass[card.title_color] ?? 'text-terminal-green']}>
          ├ {card.box_title} ┤
        </span>
        <div class="mt-2">
          <div class:list={['text-white text-sm font-bold mb-2 transition-colors', hoverClass[card.title_color] ?? '']}>
            {card.heading}
          </div>
          <div class="text-terminal-muted text-xs leading-relaxed">{card.description}</div>
        </div>
        <div class:list={['mt-3 text-xs', colorClass[card.title_color] ?? 'text-terminal-green']}>{card.cta_text}</div>
      </a>
    ))}
  </div>

  <hr class="tui-hr" />

  <!-- TOOLS panel -->
  <div class="tui-box p-3">
    <span class="tui-box-title text-terminal-green">├ TOOLS ┤</span>
    <div class="mt-2 space-y-1">
      {readyTools.map((tool) => (
        <a href={`/tools/${tool.id}`} class="flex items-center justify-between py-1 px-2 hover:bg-terminal-green/5 transition-colors group">
          <div class="flex items-center gap-2">
            <span class="text-terminal-green">│</span>
            <span class="text-gray-300 group-hover:text-terminal-green text-xs">{tool.data.title}</span>
          </div>
          <span class="text-terminal-green text-xs">[READY]</span>
        </a>
      ))}
      {soonCount > 0 && (
        <div class="flex items-center justify-between py-1 px-2">
          <div class="flex items-center gap-2">
            <span class="text-terminal-muted">│</span>
            <span class="text-terminal-muted text-xs">{soonCount} more tools in development</span>
          </div>
          <a href="/tools" class="text-terminal-cyan text-xs hover:text-terminal-green">see roadmap →</a>
        </div>
      )}
    </div>
  </div>

  <hr class="tui-hr" />

  <!-- Promise row -->
  <div class="grid grid-cols-3 gap-0 text-xs text-center py-3">
    {hp.promises.map((p, i) => (
      <div class:list={['px-2', i === 1 && 'border-x border-terminal-border']}>
        <div class:list={['font-bold mb-1', colorClass[p.color] ?? 'text-terminal-green']}>{p.icon} {p.title}</div>
        <div class="text-terminal-muted">{p.description}</div>
      </div>
    ))}
  </div>

  <!-- Social proof -->
  <div class="text-center text-terminal-muted text-[10px] py-2 border-t border-terminal-border">
    {hp.social_proof}
  </div>

  <!-- Boot sequence script -->
  <script>
    (function() {
      const boot = document.getElementById('boot-sequence');
      if (!boot) return;
      const lines = boot.querySelectorAll('.boot-line');
      if (sessionStorage.getItem('pt-booted')) {
        boot.style.display = 'none';
        return;
      }
      lines.forEach(function(line) {
        line.style.opacity = '0';
        line.style.transform = 'translateX(-8px)';
        line.style.transition = 'opacity 0.15s ease, transform 0.15s ease';
      });
      lines.forEach(function(line, i) {
        setTimeout(function() {
          line.style.opacity = '1';
          line.style.transform = 'translateX(0)';
        }, i * 150);
      });
      var totalAnimTime = lines.length * 150 + 800;
      setTimeout(function() {
        boot.style.overflow = 'hidden';
        boot.style.maxHeight = boot.scrollHeight + 'px';
        boot.offsetHeight;
        boot.style.transition = 'max-height 0.4s ease, opacity 0.3s ease, margin 0.4s ease';
        boot.style.maxHeight = '0';
        boot.style.opacity = '0';
        boot.style.marginBottom = '0';
        sessionStorage.setItem('pt-booted', '1');
      }, totalAnimTime);
    })();
  </script>
</BaseLayout>
