---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
export const prerender = true;

const challengeEntries = await getCollection('challenges');
const challengesData = challengeEntries.map(c => ({
  id: c.id,
  title: c.data.title,
  description: c.data.description,
  category: c.data.category,
  difficulty: c.data.difficulty,
  verificationTool: c.data.verificationTool,
  verificationTarget: c.data.verificationTarget,
  reward: c.data.reward,
})).sort((a, b) => a.difficulty - b.difficulty);
---

<BaseLayout
  title="Live Threat Assessment — Privacy Terminal"
  description="Scan your browser in real-time. See exactly how exposed you are across fingerprinting, IP leaks, WebRTC, DNS, cookies, and more. All client-side, zero data collected."
  statusLeft="module: threat-assessment"
  statusRight="live scan"
>
  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Live Threat Assessment",
    "description": "Real-time browser privacy scanner that checks fingerprinting, WebRTC leaks, DNS resolver, IP visibility, and more. Runs entirely client-side.",
    "applicationCategory": "SecurityApplication",
    "operatingSystem": "Web Browser",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "publisher": { "@type": "Organization", "name": "Privacy Terminal", "url": "https://privacyterminal.com" },
    "url": "https://privacyterminal.com/scan"
  })} />

  <!-- Page header -->
  <div class="flex items-center justify-between flex-wrap gap-2 mb-3">
    <div>
      <div class="text-terminal-green text-glow-green font-bold">
        ~/scan/<span class="text-white">threat-assessment</span>
      </div>
      <p class="text-terminal-muted text-xs mt-1">Real-time browser privacy scan — all processing runs locally</p>
    </div>
    <div class="flex items-center gap-2 text-xs">
      <span class="flex items-center gap-1.5">
        <span class="inline-block w-2 h-2 bg-terminal-cyan" id="scan-status-dot"></span>
        <span class="text-terminal-cyan" id="scan-status-label">READY</span>
      </span>
    </div>
  </div>

  <hr class="tui-hr" />

  <!-- Scan controls -->
  <div class="mb-4">
    <button id="btn-scan" class="px-4 py-2 border border-terminal-green text-terminal-green text-xs font-bold hover:bg-terminal-green/10 transition-colors">
      $ run threat-assessment --full
    </button>
    <span id="scan-timer" class="text-terminal-muted text-[10px] ml-3 hidden"></span>
  </div>

  <!-- Progress bar (during scan) -->
  <div id="scan-progress" class="hidden mb-4">
    <div class="tui-box p-3">
      <span class="tui-box-title text-terminal-amber">┤ SCANNING ├</span>
      <div class="mt-2">
        <div class="text-xs text-terminal-muted mb-1" id="scan-progress-label">Initializing...</div>
        <div class="flex items-center gap-2">
          <div class="flex-1 h-1.5 bg-terminal-border">
            <div class="h-full bg-terminal-green transition-all duration-300" id="scan-progress-fill" style="width: 0%"></div>
          </div>
          <span class="text-terminal-green text-[10px] font-bold w-8 text-right" id="scan-progress-pct">0%</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Main results panel (hidden until scan completes) -->
  <div id="scan-results" class="hidden">
    <!-- ASCII-art threat surface box -->
    <div class="tui-box p-4 mb-4" id="threat-surface-box">
      <span class="tui-box-title text-terminal-green">┤ THREAT SURFACE ANALYSIS ├</span>
      <div class="mt-3 space-y-2" id="threat-vectors">
        <!-- Vectors injected by JS -->
      </div>
      <hr class="tui-hr my-3" />
      <!-- Overall threat level -->
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <span class="text-terminal-muted text-xs">OVERALL THREAT LEVEL:</span>
          <span class="font-mono font-bold text-xs" id="overall-bar"></span>
          <span class="font-bold text-xs" id="overall-label"></span>
        </div>
        <span class="text-xs font-bold" id="overall-pct"></span>
      </div>
      <!-- Clearance display -->
      <div class="mt-3 flex items-center gap-2">
        <span class="text-terminal-muted text-xs">CLEARANCE:</span>
        <span class="font-bold text-xs" id="result-clearance"></span>
      </div>
    </div>

    <!-- Detailed breakdown -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4">
      <!-- Leaks -->
      <div class="tui-box p-3">
        <span class="tui-box-title text-terminal-red">┤ LEAKS ├</span>
        <div class="mt-2 space-y-1" id="detail-leaks"></div>
      </div>
      <!-- Fingerprints -->
      <div class="tui-box p-3">
        <span class="tui-box-title text-terminal-amber">┤ FINGERPRINTING ├</span>
        <div class="mt-2 space-y-1" id="detail-fingerprints"></div>
      </div>
    </div>

    <!-- Metadata -->
    <div class="tui-box p-3 mb-4">
      <span class="tui-box-title text-terminal-cyan">┤ METADATA ├</span>
      <div class="mt-2 space-y-1" id="detail-metadata"></div>
    </div>

    <!-- Progress link -->
    <div class="tui-box p-3 mb-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-terminal-green">▸</span>
          <span class="text-terminal-muted text-xs">Track your progress and see recommended learning path</span>
        </div>
        <a href="/skill-tree" class="text-terminal-cyan text-xs hover:text-terminal-green">View Skill Tree →</a>
      </div>
    </div>

    <!-- Recommended next steps -->
    <div class="tui-box p-3 mb-4">
      <span class="tui-box-title text-terminal-amber">┤ RECOMMENDED ACTIONS ├</span>
      <div class="mt-2 space-y-1" id="recommendations"></div>
    </div>

    <!-- Rescan button -->
    <div class="text-center py-3">
      <button id="btn-rescan" class="px-4 py-2 border border-terminal-cyan text-terminal-cyan text-xs font-bold hover:bg-terminal-cyan/10 transition-colors">
        $ run threat-assessment --rescan
      </button>
    </div>
  </div>

  <!-- Challenges data for client-side -->
  <script id="pt-challenges-data" type="application/json" set:html={JSON.stringify(challengesData)} />

  <!-- Before/After Progress Comparison (shown when initial scan exists) -->
  <div id="scan-comparison" class="hidden mb-4">
    <div class="tui-box p-4">
      <span class="tui-box-title text-terminal-green">┤ PROGRESS SINCE FIRST SCAN ├</span>
      <div class="mt-3 space-y-1" id="comparison-vectors">
        <!-- Delta rows injected by JS -->
      </div>
      <hr class="tui-hr my-3" />
      <div class="flex items-center justify-between">
        <div id="comparison-overall" class="text-xs font-bold"></div>
        <div id="comparison-message" class="text-xs text-terminal-muted"></div>
      </div>
      <div class="mt-3 flex items-center justify-between">
        <span class="text-terminal-muted text-[10px]">Baseline recorded on first visit</span>
        <button id="btn-reset-baseline" class="text-[10px] text-terminal-amber hover:text-terminal-green border border-terminal-amber/40 px-2 py-0.5 hover:border-terminal-green/40 transition-colors">
          Reset baseline
        </button>
      </div>
    </div>
  </div>

  <!-- Active Challenges -->
  <div id="scan-challenges" class="hidden mb-4">
    <div class="tui-box p-4">
      <span class="tui-box-title text-terminal-cyan">┤ ACTIVE CHALLENGES ├</span>
      <div class="mt-3 space-y-2" id="challenges-list">
        <!-- Challenge rows injected by JS -->
      </div>
      <hr class="tui-hr my-3" />
      <div class="flex items-center justify-between text-xs">
        <span class="text-terminal-muted" id="challenges-summary">0 / 0 completed</span>
        <a href="/dossier" class="text-terminal-cyan hover:text-terminal-green">View full dossier →</a>
      </div>
    </div>
  </div>

  <!-- Educational footer -->
  <div class="mt-6">
    <hr class="tui-hr" />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs text-terminal-muted py-3">
      <div>
        <span class="text-terminal-green font-bold">What does this scan do?</span>
        <p class="mt-1">This scanner checks your browser across 11 privacy vectors in real-time. It detects IP leaks, WebRTC exposure, DNS resolver type, fingerprinting surfaces, and browser metadata. All checks run entirely in your browser — no data is sent to Privacy Terminal.</p>
      </div>
      <div>
        <span class="text-terminal-green font-bold">How do I improve my score?</span>
        <p class="mt-1">Follow our guides to reduce your attack surface. Start with the <a href="/guides/the-5-minute-privacy-checkup" class="text-terminal-cyan hover:text-terminal-green">5-Minute Privacy Checkup</a>, then work through the <a href="/guides" class="text-terminal-cyan hover:text-terminal-green">guides</a> to address each threat vector. Re-scan after making changes to see your improvement.</p>
        <p class="mt-1"><span class="text-terminal-amber">Note:</span> IP and DNS checks use our <a href="/privacy" class="text-terminal-cyan hover:text-terminal-green">privacy-respecting API</a> to detect your resolver type. No data is logged or stored.</p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
import { runThreatScan, type ScanResult, type ScanVector } from '../scripts/threat-scanner';
import {
  calculateClearance, getProgressSummary, saveScanResults,
  getInitialScan, resetBaseline, evaluateChallenges, getCompletedChallenges,
  RECON_GUIDES, HARDENING_GUIDES,
  CLEARANCE_LEVELS, renderBar, exposureLabel, exposureColor,
  type ScanSnapshot, type ChallengeData
} from '../scripts/gamification';
import { trackTool, unlockAchievement, getCachedProgress } from '../scripts/privacy-score';

// ── Load challenges data from DOM ──
let challengesList: ChallengeData[] = [];
try {
  const chEl = document.getElementById('pt-challenges-data');
  if (chEl?.textContent) challengesList = JSON.parse(chEl.textContent);
} catch { /* ignore */ }

// ── DOM refs ──
const btnScan = document.getElementById('btn-scan') as HTMLButtonElement;
const btnRescan = document.getElementById('btn-rescan') as HTMLButtonElement | null;
const scanProgress = document.getElementById('scan-progress')!;
const scanResults = document.getElementById('scan-results')!;
const progressLabel = document.getElementById('scan-progress-label')!;
const progressFill = document.getElementById('scan-progress-fill')!;
const progressPct = document.getElementById('scan-progress-pct')!;
const statusDot = document.getElementById('scan-status-dot')!;
const statusLabel = document.getElementById('scan-status-label')!;
const scanTimer = document.getElementById('scan-timer')!;

// ── Read API base from game config ──
let apiBase = 'https://privacyterminal-api.terinmain.workers.dev';
try {
  const el = document.getElementById('pt-game-data');
  if (el?.textContent) {
    const gd = JSON.parse(el.textContent);
    if (gd.apiBase) apiBase = gd.apiBase;
  }
} catch { /* use default */ }

// ── Helpers ──
function setStatus(status: 'ready' | 'running' | 'complete' | 'error') {
  const colors: Record<string, string> = {
    ready: 'bg-terminal-cyan', running: 'bg-terminal-amber',
    complete: 'bg-terminal-green', error: 'bg-terminal-red'
  };
  const textColors: Record<string, string> = {
    ready: 'text-terminal-cyan', running: 'text-terminal-amber',
    complete: 'text-terminal-green', error: 'text-terminal-red'
  };
  const labels: Record<string, string> = {
    ready: 'READY', running: 'SCANNING...', complete: 'COMPLETE', error: 'ERROR'
  };
  statusDot.className = `inline-block w-2 h-2 ${colors[status]}${status === 'running' ? ' animate-pulse' : ''}`;
  statusLabel.className = textColors[status];
  statusLabel.textContent = labels[status];
}

function severityColor(sev: number): string {
  if (sev >= 70) return 'text-terminal-red';
  if (sev >= 40) return 'text-terminal-amber';
  if (sev >= 15) return 'text-terminal-cyan';
  return 'text-terminal-green';
}

function statusColor(status: string): string {
  const s = status.toUpperCase();
  if (s.includes('EXPOSED') || s.includes('ISP') || s.includes('UNIQUE') || s.includes('ENABLED') || s.includes('LEAKING')) return 'text-terminal-red';
  if (s.includes('VPN IP LEAK') || s.includes('CONSISTENT') || s.includes('UNVERIFIED') || s.includes('PERMISSIVE') || s.includes('DATACENTER') || s.includes('PRIVATE IP')) return 'text-terminal-amber';
  if (s.includes('PROTECTED') || s.includes('HIDDEN') || s.includes('ENCRYPTED') || s.includes('VPN') || s.includes('TOR') || s.includes('CLEAN') || s.includes('STRICT') || s.includes('RANDOMIZED') || s.includes('BLOCKED') || s.includes('HARDENED') || s.includes('RESTRICTED') || s.includes('MDNS') || s.includes('MINIMAL')) return 'text-terminal-green';
  if (s.includes('ON')) return 'text-terminal-green';
  if (s.includes('OFF')) return 'text-terminal-amber';
  return 'text-terminal-amber';
}

function renderVectorRow(v: ScanVector): string {
  const bar = renderBar(v.severity, 100, 14);
  const sCol = severityColor(v.severity);
  const stCol = statusColor(v.status);
  return `<div class="flex items-center gap-2 text-xs py-0.5">
    <span class="text-terminal-muted w-[140px] shrink-0 truncate">${v.label}</span>
    <span class="${sCol} font-mono text-[11px] hidden sm:inline">${bar}</span>
    <span class="${stCol} font-bold shrink-0 text-right ml-auto">${v.status}</span>
  </div>`;
}

function renderDetailRow(v: ScanVector): string {
  const stCol = statusColor(v.status);
  return `<div class="flex items-start justify-between gap-2 py-1 text-xs border-b border-terminal-border/30 last:border-0">
    <div class="min-w-0">
      <div class="flex items-center gap-2">
        <span class="${stCol} font-bold text-[10px] shrink-0">[${v.status}]</span>
        <span class="text-gray-300 font-bold">${v.label}</span>
      </div>
      <div class="text-terminal-muted text-[10px] mt-0.5">${v.detail}</div>
    </div>
    <div class="shrink-0 text-right">
      <span class="${severityColor(v.severity)} font-bold text-[10px]">${v.severity}%</span>
    </div>
  </div>`;
}

function guideNameFromSlug(slug: string): string {
  return slug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}

// ── Render results ──
function displayResults(result: ScanResult) {
  // Threat vectors summary
  const vectorsEl = document.getElementById('threat-vectors')!;
  vectorsEl.innerHTML = result.vectors.map(renderVectorRow).join('');

  // Overall bar
  const overall = result.overall_exposure;
  const oBar = renderBar(overall, 100, 14);
  const oLabel = exposureLabel(overall);
  const oColor = exposureColor(overall);
  document.getElementById('overall-bar')!.innerHTML = `<span class="${oColor}">${oBar}</span>`;
  document.getElementById('overall-label')!.innerHTML = `<span class="${oColor}">${oLabel}</span>`;
  document.getElementById('overall-pct')!.innerHTML = `<span class="${oColor}">${overall}%</span>`;

  // Clearance
  const cl = calculateClearance();
  const clEl = document.getElementById('result-clearance')!;
  const colorMap: Record<string, string> = {
    gray: 'text-gray-500', white: 'text-gray-200', green: 'text-terminal-green',
    cyan: 'text-terminal-cyan', amber: 'text-terminal-amber', red: 'text-terminal-red',
  };
  clEl.innerHTML = `<span class="${colorMap[cl.tailwindColor] || 'text-gray-500'}">LEVEL ${cl.level} / ${cl.name}</span>`;

  // Category breakdowns
  const leaks = result.vectors.filter(v => v.category === 'leak');
  const fps = result.vectors.filter(v => v.category === 'fingerprint');
  const meta = result.vectors.filter(v => v.category === 'metadata');
  document.getElementById('detail-leaks')!.innerHTML = leaks.map(renderDetailRow).join('');
  document.getElementById('detail-fingerprints')!.innerHTML = fps.map(renderDetailRow).join('');
  document.getElementById('detail-metadata')!.innerHTML = meta.map(renderDetailRow).join('');

  // Progress summary for recommendations
  const summary = getProgressSummary();

  // Recommendations
  const recs: string[] = [];
  const recVectors = result.vectors.filter(v => v.severity >= 40).sort((a, b) => b.severity - a.severity);
  const vectorGuideMap: Record<string, string> = {
    webrtc: 'browser-fingerprinting-explained',
    dns: 'dns-privacy-explained',
    ip: 'vpns-what-they-actually-protect',
    canvas: 'browser-fingerprinting-explained',
    webgl: 'browser-fingerprinting-explained',
    fonts: 'browser-fingerprinting-explained',
    cookies: 'choosing-a-browser-for-privacy',
    javascript: 'choosing-a-browser-for-privacy',
    referrer: 'choosing-a-browser-for-privacy',
    dnt: 'the-5-minute-privacy-checkup',
    screen: 'browser-fingerprinting-explained',
  };

  for (const v of recVectors.slice(0, 5)) {
    const guide = vectorGuideMap[v.id];
    const link = guide ? ` → <a href="/guides/${guide}" class="text-terminal-cyan hover:text-terminal-green">${guideNameFromSlug(guide)}</a>` : '';
    recs.push(`<div class="text-xs py-0.5"><span class="text-terminal-green">▸</span> <span class="text-gray-300">Fix <strong class="${severityColor(v.severity)}">${v.label}</strong> (${v.severity}% exposure)</span>${link}</div>`);
  }

  // Add tier recommendations
  if (summary.recon.completed.length < summary.recon.total) {
    const remaining = RECON_GUIDES.filter(g => !summary.recon.completed.includes(g));
    if (remaining.length > 0) {
      recs.push(`<div class="text-xs py-0.5"><span class="text-terminal-green">▸</span> <span class="text-gray-300">Complete Recon tier: <a href="/guides/${remaining[0]}" class="text-terminal-cyan hover:text-terminal-green">${guideNameFromSlug(remaining[0])}</a> (+${remaining.length - 1} more)</span></div>`);
    }
  }

  if (recs.length === 0) {
    recs.push('<div class="text-xs text-terminal-green py-1">✓ No critical recommendations — your privacy posture is strong!</div>');
  }

  document.getElementById('recommendations')!.innerHTML = recs.join('');
}

// ── Scan handler ──
let isScanning = false;

async function executeScan() {
  if (isScanning) return;
  isScanning = true;

  btnScan.disabled = true;
  btnScan.textContent = 'scanning...';
  setStatus('running');
  scanProgress.classList.remove('hidden');
  scanResults.classList.add('hidden');
  scanTimer.classList.remove('hidden');

  const startTime = performance.now();
  const timerInterval = setInterval(() => {
    const elapsed = ((performance.now() - startTime) / 1000).toFixed(1);
    scanTimer.textContent = `${elapsed}s elapsed`;
  }, 100);

  try {
    const result = await runThreatScan(apiBase, (msg, pct) => {
      progressLabel.textContent = msg;
      progressFill.style.width = `${pct}%`;
      progressPct.textContent = `${pct}%`;
    });

    clearInterval(timerInterval);
    const elapsed = ((performance.now() - startTime) / 1000).toFixed(1);
    scanTimer.textContent = `completed in ${elapsed}s`;

    // Save scan to localStorage
    const snapshot: ScanSnapshot = {
      overall_exposure: result.overall_exposure,
      timestamp: result.timestamp,
      vectors: result.vectors.map(v => ({
        id: v.id,
        severity: v.severity,
        status: v.status,
      })),
    };
    saveScanResults(snapshot);

    // Display results
    displayResults(result);
    scanProgress.classList.add('hidden');
    scanResults.classList.remove('hidden');
    setStatus('complete');

    // Track tool usage
    try {
      await trackTool('leak-tester');
      await trackTool('fingerprint-analyzer');
      await trackTool('webrtc-detector');
      await unlockAchievement('FIRST_SCAN');
      await unlockAchievement('THREAT_ASSESSED');
    } catch { /* gamification optional */ }

    // Show Before/After comparison
    showComparison(snapshot);

    // Evaluate and show challenges
    showChallenges();

  } catch (err) {
    clearInterval(timerInterval);
    setStatus('error');
    progressLabel.textContent = `Error: ${err instanceof Error ? err.message : 'Scan failed'}`;
  } finally {
    isScanning = false;
    btnScan.disabled = false;
    btnScan.textContent = '$ run threat-assessment --full';
  }
}

btnScan.addEventListener('click', executeScan);
btnRescan?.addEventListener('click', executeScan);

// ── Before/After Comparison ──
function showComparison(latest: ScanSnapshot) {
  const initial = getInitialScan();
  const compSection = document.getElementById('scan-comparison')!;
  const compVectors = document.getElementById('comparison-vectors')!;
  const compOverall = document.getElementById('comparison-overall')!;
  const compMessage = document.getElementById('comparison-message')!;

  if (!initial || initial.timestamp === latest.timestamp) {
    compSection.classList.add('hidden');
    return;
  }

  // Check if there's actually any difference
  if (initial.overall_exposure === latest.overall_exposure) {
    compSection.classList.add('hidden');
    return;
  }

  const rows: string[] = [];
  for (const lv of latest.vectors) {
    const iv = initial.vectors.find(v => v.id === lv.id);
    if (!iv) continue;
    if (iv.severity === lv.severity && iv.status === lv.status) continue;

    const delta = iv.severity - lv.severity;
    const improved = delta > 0;
    const statusChanged = iv.status !== lv.status;

    let deltaStr = '';
    if (delta !== 0) {
      deltaStr = improved
        ? `<span class="text-terminal-green">▼${delta}%</span>`
        : `<span class="text-terminal-red">▲${Math.abs(delta)}%</span>`;
    }

    let badge = '';
    if (improved && lv.severity <= 10) {
      badge = '<span class="text-terminal-green">✓ FIXED</span>';
    } else if (improved) {
      badge = '<span class="text-terminal-green">✓ IMPROVED</span>';
    } else if (!improved && delta !== 0) {
      badge = '<span class="text-terminal-red">⚠ REGRESSED</span>';
    }

    const label = lv.id.toUpperCase().replace(/_/g, ' ');
    if (statusChanged) {
      rows.push(`<div class="flex items-center justify-between text-xs py-0.5">
        <span class="text-terminal-muted w-[120px] shrink-0">${label}</span>
        <span class="text-gray-400">${iv.status} → <span class="text-white">${lv.status}</span></span>
        <span class="ml-auto pl-2">${deltaStr} ${badge}</span>
      </div>`);
    } else {
      rows.push(`<div class="flex items-center justify-between text-xs py-0.5">
        <span class="text-terminal-muted w-[120px] shrink-0">${label}</span>
        <span class="text-gray-400">${iv.severity}% → <span class="text-white">${lv.severity}%</span></span>
        <span class="ml-auto pl-2">${deltaStr} ${badge}</span>
      </div>`);
    }
  }

  if (rows.length === 0) {
    compSection.classList.add('hidden');
    return;
  }

  compVectors.innerHTML = rows.join('');

  const overallDelta = initial.overall_exposure - latest.overall_exposure;
  const oColor = overallDelta > 0 ? 'text-terminal-green' : overallDelta < 0 ? 'text-terminal-red' : 'text-terminal-muted';
  const arrow = overallDelta > 0 ? '▼' : overallDelta < 0 ? '▲' : '';
  compOverall.innerHTML = `<span class="${oColor}">OVERALL: ${initial.overall_exposure}% → ${latest.overall_exposure}%  ${arrow}${Math.abs(overallDelta)}% ${overallDelta > 0 ? 'IMPROVEMENT' : overallDelta < 0 ? 'REGRESSION' : 'NO CHANGE'}</span>`;

  if (overallDelta > 30) {
    compMessage.textContent = 'Excellent progress! Your privacy posture is significantly stronger.';
  } else if (overallDelta > 10) {
    compMessage.textContent = 'Good improvement! Keep going — complete more guides to reduce further.';
  } else if (overallDelta > 0) {
    compMessage.textContent = 'Some improvement detected. Follow the recommended actions for bigger gains.';
  } else {
    compMessage.textContent = 'Your exposure has increased. Review the recommended actions below.';
  }

  compSection.classList.remove('hidden');
}

// ── Challenges Display ──
function showChallenges() {
  if (challengesList.length === 0) return;

  // Auto-complete eligible challenges
  evaluateChallenges(challengesList);

  const completed = getCompletedChallenges();
  const chSection = document.getElementById('scan-challenges')!;
  const chList = document.getElementById('challenges-list')!;
  const chSummary = document.getElementById('challenges-summary')!;

  const rows = challengesList.map(ch => {
    const done = completed.includes(ch.id);
    const stars = '★'.repeat(ch.difficulty) + '<span class="text-terminal-border">' + '☆'.repeat(5 - ch.difficulty) + '</span>';
    const icon = done
      ? '<span class="text-terminal-green">[■]</span>'
      : '<span class="text-terminal-muted">[□]</span>';
    const titleColor = done ? 'text-terminal-green' : 'text-white';
    const doneLabel = done ? '<span class="text-terminal-green text-[10px] ml-2">✓ DONE</span>' : '';
    const catColor = ch.category === 'hardening' ? 'text-terminal-cyan' : ch.category === 'recon' ? 'text-terminal-green' : 'text-terminal-amber';

    return `<div class="flex items-start gap-2 text-xs py-1 border-b border-terminal-border/20 last:border-0">
      <span class="shrink-0 mt-0.5 font-mono">${icon}</span>
      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="${titleColor} font-bold text-[11px]">${ch.title.toUpperCase()}</span>
          <span class="text-[10px]">${stars}</span>
          <span class="${catColor} text-[9px] border border-current/30 px-1 py-px">${ch.category.toUpperCase()}</span>
          <span class="text-terminal-amber text-[10px]">${ch.reward}pts</span>
          ${doneLabel}
        </div>
        <div class="text-terminal-muted text-[10px] mt-0.5">${ch.description}</div>
      </div>
    </div>`;
  });

  chList.innerHTML = rows.join('');
  const completedCount = challengesList.filter(ch => completed.includes(ch.id)).length;
  const totalReward = challengesList.filter(ch => completed.includes(ch.id)).reduce((sum, ch) => sum + ch.reward, 0);
  chSummary.textContent = `${completedCount} / ${challengesList.length} completed · ${totalReward} pts earned`;
  chSection.classList.remove('hidden');
}

// ── Reset Baseline Handler ──
document.getElementById('btn-reset-baseline')?.addEventListener('click', () => {
  resetBaseline();
  const compSection = document.getElementById('scan-comparison')!;
  compSection.classList.add('hidden');
  // Show brief confirmation
  const btn = document.getElementById('btn-reset-baseline')!;
  const orig = btn.textContent;
  btn.textContent = '✓ Baseline reset';
  btn.classList.add('text-terminal-green', 'border-terminal-green/40');
  btn.classList.remove('text-terminal-amber', 'border-terminal-amber/40');
  setTimeout(() => {
    btn.textContent = orig;
    btn.classList.remove('text-terminal-green', 'border-terminal-green/40');
    btn.classList.add('text-terminal-amber', 'border-terminal-amber/40');
  }, 2000);
});

// Show challenges on page load if scan data exists (user revisiting)
(function initOnLoad() {
  if (challengesList.length > 0) {
    const scan = localStorage.getItem('pt_latest_scan');
    if (scan) showChallenges();
  }
})();
</script>
