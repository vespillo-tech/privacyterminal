---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout title="Privacy Resources — Best Tools, Organizations & Communities | Privacy Terminal" description="Curated directory of the best privacy resources: EFF, Tor Project, Mullvad VPN, Signal, and 40+ vetted privacy tools, organizations, and communities. No affiliate links.">
  <div class="max-w-5xl mx-auto px-4 py-8">

    <pre class="text-terminal-green text-center text-xs sm:text-sm mb-4 overflow-x-auto">
╔══════════════════════════════════════════════════════════╗
║          PRIVACY TERMINAL — DEPARTURES BOARD             ║
║    Your gateway to privacy destinations worldwide         ║
╚══════════════════════════════════════════════════════════╝
    </pre>

    <p class="text-terminal-muted text-center mb-8 text-sm">
      A curated collection of the best privacy resources on the internet.<br/>
      Every link vetted. No affiliate deals. No sponsored listings. Just good destinations.
    </p>

    <!-- GATE 1: Organizations -->
    <section class="mb-8">
      <div class="text-terminal-amber font-bold mb-3">┌─── GATE 1: Organizations & Advocacy ───────────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.eff.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Electronic Frontier Foundation (EFF)</a>
          <span class="text-terminal-muted"> — Leading digital rights nonprofit. Legal advocacy, tools, research.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.privacyguides.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Privacy Guides</a>
          <span class="text-terminal-muted"> — Community-driven privacy tool recommendations. Non-profit, no affiliates.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.torproject.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">The Tor Project</a>
          <span class="text-terminal-muted"> — Anonymity network and browser. The gold standard for anonymous browsing.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://freedom.press" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Freedom of the Press Foundation</a>
          <span class="text-terminal-muted"> — Protecting journalists and whistleblowers. Maintains SecureDrop.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://epic.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">EPIC</a>
          <span class="text-terminal-muted"> — Electronic Privacy Information Center. Policy research and advocacy.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.accessnow.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Access Now</a>
          <span class="text-terminal-muted"> — Defending digital rights globally. Runs a digital security helpline.</span>
        </div>
      </div>
      <div class="text-terminal-amber">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 2: Privacy Tools -->
    <section class="mb-8">
      <div class="text-terminal-amber font-bold mb-3">┌─── GATE 2: Privacy Tools & Software ──────────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-terminal-border pl-4">
          <a href="https://mullvad.net" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Mullvad VPN</a>
          <span class="text-terminal-muted"> — No-account, anonymous-payment VPN. No affiliate program (that's the point).</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://signal.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Signal</a>
          <span class="text-terminal-muted"> — End-to-end encrypted messaging. Open source. The standard for private chat.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://proton.me" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Proton (Mail, VPN, Drive)</a>
          <span class="text-terminal-muted"> — Swiss-based encrypted email, VPN, cloud storage, and calendar suite.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://bitwarden.com" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Bitwarden</a>
          <span class="text-terminal-muted"> — Open-source password manager. Free tier is generous. Audited.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.mozilla.org/firefox/" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Firefox</a>
          <span class="text-terminal-muted"> — Privacy-configurable browser. The best balance of usability and privacy.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://librewolf.net" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">LibreWolf</a>
          <span class="text-terminal-muted"> — Pre-hardened Firefox fork. Telemetry removed, privacy settings maxed.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://brave.com" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Brave Browser</a>
          <span class="text-terminal-muted"> — Built-in ad/tracker blocking. Chromium-based. Easy switch from Chrome.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://ublockorigin.com" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">uBlock Origin</a>
          <span class="text-terminal-muted"> — Best-in-class content blocker. Essential browser extension.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://keepassxc.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">KeePassXC</a>
          <span class="text-terminal-muted"> — Offline, open-source password manager. Your vault never leaves your device.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.duckduckgo.com" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">DuckDuckGo</a>
          <span class="text-terminal-muted"> — Privacy-respecting search engine. No search history tracking.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://searx.github.io/searx/" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">SearXNG</a>
          <span class="text-terminal-muted"> — Self-hostable metasearch engine. Maximum search privacy.</span>
        </div>
      </div>
      <div class="text-terminal-amber">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 3: Testing & Analysis -->
    <section class="mb-8">
      <div class="text-terminal-amber font-bold mb-3">┌─── GATE 3: Testing & Analysis Tools ──────────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-terminal-border pl-4">
          <a href="https://coveryourtracks.eff.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Cover Your Tracks (EFF)</a>
          <span class="text-terminal-muted"> — Test your browser's fingerprint and tracking protection.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://browserleaks.com" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">BrowserLeaks</a>
          <span class="text-terminal-muted"> — Comprehensive browser privacy leak testing suite.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://amiunique.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Am I Unique?</a>
          <span class="text-terminal-muted"> — Academic browser fingerprint analysis. See how unique you are.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://privacytests.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">PrivacyTests.org</a>
          <span class="text-terminal-muted"> — Open-source automated browser privacy comparison tests.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.dnsleaktest.com" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">DNS Leak Test</a>
          <span class="text-terminal-muted"> — Check if your DNS queries are leaking outside your VPN.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://ipleak.net" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">IPLeak.net</a>
          <span class="text-terminal-muted"> — Comprehensive IP, DNS, WebRTC, and torrent leak testing.</span>
        </div>
      </div>
      <div class="text-terminal-amber">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 4: Education & News -->
    <section class="mb-8">
      <div class="text-terminal-amber font-bold mb-3">┌─── GATE 4: Education & News ──────────────────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-terminal-border pl-4">
          <a href="https://ssd.eff.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Surveillance Self-Defense (EFF)</a>
          <span class="text-terminal-muted"> — Expert guide to protecting yourself from online surveillance.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://themarkup.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">The Markup</a>
          <span class="text-terminal-muted"> — Data-driven investigative journalism on technology and privacy.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.schneier.com" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Schneier on Security</a>
          <span class="text-terminal-muted"> — Bruce Schneier's blog. Decades of security and privacy analysis.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.techdirt.com" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Techdirt</a>
          <span class="text-terminal-muted"> — Technology policy, surveillance, and digital rights reporting.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://krebsonsecurity.com" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Krebs on Security</a>
          <span class="text-terminal-muted"> — Investigative security journalism by Brian Krebs.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://thehackernews.com" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">The Hacker News</a>
          <span class="text-terminal-muted"> — Cybersecurity news, vulnerabilities, and data breach reporting.</span>
        </div>
      </div>
      <div class="text-terminal-amber">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 5: Communities -->
    <section class="mb-8">
      <div class="text-terminal-amber font-bold mb-3">┌─── GATE 5: Communities ───────────────────────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.reddit.com/r/privacy/" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">r/privacy</a>
          <span class="text-terminal-muted"> — Reddit's largest privacy community. News, discussion, advice.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.reddit.com/r/PrivacyGuides/" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">r/PrivacyGuides</a>
          <span class="text-terminal-muted"> — Discussion forum for Privacy Guides recommendations.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://lemmy.ml/c/privacy" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Lemmy Privacy Community</a>
          <span class="text-terminal-muted"> — Federated, Reddit-alternative privacy discussion.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://discuss.privacyguides.net" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Privacy Guides Forum</a>
          <span class="text-terminal-muted"> — Official discussion forum for privacy topics and tool recommendations.</span>
        </div>
      </div>
      <div class="text-terminal-amber">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 6: Operating Systems -->
    <section class="mb-8">
      <div class="text-terminal-amber font-bold mb-3">┌─── GATE 6: Privacy-Focused Operating Systems ─────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-terminal-border pl-4">
          <a href="https://tails.net" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Tails</a>
          <span class="text-terminal-muted"> — Portable OS that routes everything through Tor. Leaves no trace.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.qubes-os.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Qubes OS</a>
          <span class="text-terminal-muted"> — Security through compartmentalization. Each app in its own VM.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://www.whonix.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Whonix</a>
          <span class="text-terminal-muted"> — Desktop OS designed for advanced security and privacy. Tor-based.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://grapheneos.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">GrapheneOS</a>
          <span class="text-terminal-muted"> — Hardened Android for Pixel phones. Best mobile privacy OS.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://calyxos.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">CalyxOS</a>
          <span class="text-terminal-muted"> — Privacy-focused Android with microG. Easier than GrapheneOS.</span>
        </div>
      </div>
      <div class="text-terminal-amber">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 7: Data Removal -->
    <section class="mb-8">
      <div class="text-terminal-amber font-bold mb-3">┌─── GATE 7: Data Removal & Self-Defense ───────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-terminal-border pl-4">
          <a href="https://justdeleteme.xyz" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Just Delete Me</a>
          <span class="text-terminal-muted"> — Direct links to delete your accounts on hundreds of services.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://github.com/pluja/awesome-privacy" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Awesome Privacy (GitHub)</a>
          <span class="text-terminal-muted"> — Massive curated list of privacy-respecting service alternatives.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://haveibeenpwned.com" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Have I Been Pwned</a>
          <span class="text-terminal-muted"> — Check if your email/password appeared in data breaches.</span>
        </div>
        <div class="border-l border-terminal-border pl-4">
          <a href="https://tosdr.org" target="_blank" rel="noopener" class="text-terminal-cyan hover:text-terminal-green">Terms of Service; Didn't Read</a>
          <span class="text-terminal-muted"> — Human-readable ratings of website terms of service and privacy policies.</span>
        </div>
      </div>
      <div class="text-terminal-amber">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- Footer note -->
    <div class="text-center text-terminal-muted text-xs mt-8 mb-4">
      <p>This terminal has no affiliate relationships with any listed destination.</p>
      <p>All links are recommendations based on research and community consensus.</p>
      <p class="text-terminal-muted mt-2">Last updated: March 2026 │ Suggest a destination: <a href="https://github.com/vespillo-tech/privacyterminal" class="text-terminal-cyan hover:text-terminal-green">GitHub</a></p>
    </div>

  </div>
</BaseLayout>
