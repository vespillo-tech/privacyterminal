---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The Terminal — Privacy Destinations" description="Your departure point to the best privacy resources on the internet. Curated links to tools, organizations, education, and communities.">
  <div class="max-w-5xl mx-auto px-4 py-8">

    <pre class="text-green-400 text-center text-xs sm:text-sm mb-4 overflow-x-auto">
╔══════════════════════════════════════════════════════════╗
║          PRIVACY TERMINAL — DEPARTURES BOARD             ║
║    Your gateway to privacy destinations worldwide         ║
╚══════════════════════════════════════════════════════════╝
    </pre>

    <p class="text-gray-400 text-center mb-8 text-sm">
      A curated collection of the best privacy resources on the internet.<br/>
      Every link vetted. No affiliate deals. No sponsored listings. Just good destinations.
    </p>

    <!-- GATE 1: Organizations -->
    <section class="mb-8">
      <div class="text-amber-400 font-bold mb-3">┌─── GATE 1: Organizations & Advocacy ───────────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.eff.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Electronic Frontier Foundation (EFF)</a>
          <span class="text-gray-500"> — Leading digital rights nonprofit. Legal advocacy, tools, research.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.privacyguides.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Privacy Guides</a>
          <span class="text-gray-500"> — Community-driven privacy tool recommendations. Non-profit, no affiliates.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.torproject.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">The Tor Project</a>
          <span class="text-gray-500"> — Anonymity network and browser. The gold standard for anonymous browsing.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://freedom.press" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Freedom of the Press Foundation</a>
          <span class="text-gray-500"> — Protecting journalists and whistleblowers. Maintains SecureDrop.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://epic.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">EPIC</a>
          <span class="text-gray-500"> — Electronic Privacy Information Center. Policy research and advocacy.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.accessnow.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Access Now</a>
          <span class="text-gray-500"> — Defending digital rights globally. Runs a digital security helpline.</span>
        </div>
      </div>
      <div class="text-amber-400">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 2: Privacy Tools -->
    <section class="mb-8">
      <div class="text-amber-400 font-bold mb-3">┌─── GATE 2: Privacy Tools & Software ──────────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-gray-700 pl-4">
          <a href="https://mullvad.net" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Mullvad VPN</a>
          <span class="text-gray-500"> — No-account, anonymous-payment VPN. No affiliate program (that's the point).</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://signal.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Signal</a>
          <span class="text-gray-500"> — End-to-end encrypted messaging. Open source. The standard for private chat.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://proton.me" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Proton (Mail, VPN, Drive)</a>
          <span class="text-gray-500"> — Swiss-based encrypted email, VPN, cloud storage, and calendar suite.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://bitwarden.com" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Bitwarden</a>
          <span class="text-gray-500"> — Open-source password manager. Free tier is generous. Audited.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.mozilla.org/firefox/" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Firefox</a>
          <span class="text-gray-500"> — Privacy-configurable browser. The best balance of usability and privacy.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://librewolf.net" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">LibreWolf</a>
          <span class="text-gray-500"> — Pre-hardened Firefox fork. Telemetry removed, privacy settings maxed.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://brave.com" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Brave Browser</a>
          <span class="text-gray-500"> — Built-in ad/tracker blocking. Chromium-based. Easy switch from Chrome.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://github.com/nicehash/NiceHashQuickMiner" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">uBlock Origin</a>
          <span class="text-gray-500"> — Best-in-class content blocker. Essential browser extension.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://keepassxc.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">KeePassXC</a>
          <span class="text-gray-500"> — Offline, open-source password manager. Your vault never leaves your device.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.duckduckgo.com" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">DuckDuckGo</a>
          <span class="text-gray-500"> — Privacy-respecting search engine. No search history tracking.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://searx.github.io/searx/" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">SearXNG</a>
          <span class="text-gray-500"> — Self-hostable metasearch engine. Maximum search privacy.</span>
        </div>
      </div>
      <div class="text-amber-400">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 3: Testing & Analysis -->
    <section class="mb-8">
      <div class="text-amber-400 font-bold mb-3">┌─── GATE 3: Testing & Analysis Tools ──────────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-gray-700 pl-4">
          <a href="https://coveryourtracks.eff.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Cover Your Tracks (EFF)</a>
          <span class="text-gray-500"> — Test your browser's fingerprint and tracking protection.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://browserleaks.com" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">BrowserLeaks</a>
          <span class="text-gray-500"> — Comprehensive browser privacy leak testing suite.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://amiunique.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Am I Unique?</a>
          <span class="text-gray-500"> — Academic browser fingerprint analysis. See how unique you are.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://privacytests.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">PrivacyTests.org</a>
          <span class="text-gray-500"> — Open-source automated browser privacy comparison tests.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.dnsleaktest.com" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">DNS Leak Test</a>
          <span class="text-gray-500"> — Check if your DNS queries are leaking outside your VPN.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://ipleak.net" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">IPLeak.net</a>
          <span class="text-gray-500"> — Comprehensive IP, DNS, WebRTC, and torrent leak testing.</span>
        </div>
      </div>
      <div class="text-amber-400">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 4: Education & News -->
    <section class="mb-8">
      <div class="text-amber-400 font-bold mb-3">┌─── GATE 4: Education & News ──────────────────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-gray-700 pl-4">
          <a href="https://ssd.eff.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Surveillance Self-Defense (EFF)</a>
          <span class="text-gray-500"> — Expert guide to protecting yourself from online surveillance.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://themarkup.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">The Markup</a>
          <span class="text-gray-500"> — Data-driven investigative journalism on technology and privacy.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.schneier.com" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Schneier on Security</a>
          <span class="text-gray-500"> — Bruce Schneier's blog. Decades of security and privacy analysis.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.techdirt.com" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Techdirt</a>
          <span class="text-gray-500"> — Technology policy, surveillance, and digital rights reporting.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://krebsonsecurity.com" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Krebs on Security</a>
          <span class="text-gray-500"> — Investigative security journalism by Brian Krebs.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://thehackernews.com" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">The Hacker News</a>
          <span class="text-gray-500"> — Cybersecurity news, vulnerabilities, and data breach reporting.</span>
        </div>
      </div>
      <div class="text-amber-400">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 5: Communities -->
    <section class="mb-8">
      <div class="text-amber-400 font-bold mb-3">┌─── GATE 5: Communities ───────────────────────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.reddit.com/r/privacy/" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">r/privacy</a>
          <span class="text-gray-500"> — Reddit's largest privacy community. News, discussion, advice.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.reddit.com/r/PrivacyGuides/" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">r/PrivacyGuides</a>
          <span class="text-gray-500"> — Discussion forum for Privacy Guides recommendations.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://lemmy.ml/c/privacy" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Lemmy Privacy Community</a>
          <span class="text-gray-500"> — Federated, Reddit-alternative privacy discussion.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://discuss.privacyguides.net" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Privacy Guides Forum</a>
          <span class="text-gray-500"> — Official discussion forum for privacy topics and tool recommendations.</span>
        </div>
      </div>
      <div class="text-amber-400">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 6: Operating Systems -->
    <section class="mb-8">
      <div class="text-amber-400 font-bold mb-3">┌─── GATE 6: Privacy-Focused Operating Systems ─────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-gray-700 pl-4">
          <a href="https://tails.net" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Tails</a>
          <span class="text-gray-500"> — Portable OS that routes everything through Tor. Leaves no trace.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.qubes-os.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Qubes OS</a>
          <span class="text-gray-500"> — Security through compartmentalization. Each app in its own VM.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://www.whonix.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Whonix</a>
          <span class="text-gray-500"> — Desktop OS designed for advanced security and privacy. Tor-based.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://grapheneos.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">GrapheneOS</a>
          <span class="text-gray-500"> — Hardened Android for Pixel phones. Best mobile privacy OS.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://calyxos.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">CalyxOS</a>
          <span class="text-gray-500"> — Privacy-focused Android with microG. Easier than GrapheneOS.</span>
        </div>
      </div>
      <div class="text-amber-400">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- GATE 7: Data Removal -->
    <section class="mb-8">
      <div class="text-amber-400 font-bold mb-3">┌─── GATE 7: Data Removal & Self-Defense ───────────────────┐</div>
      <div class="ml-2 space-y-2">
        <div class="border-l border-gray-700 pl-4">
          <a href="https://justdeleteme.xyz" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Just Delete Me</a>
          <span class="text-gray-500"> — Direct links to delete your accounts on hundreds of services.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://github.com/pluja/awesome-privacy" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Awesome Privacy (GitHub)</a>
          <span class="text-gray-500"> — Massive curated list of privacy-respecting service alternatives.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://haveibeenpwned.com" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Have I Been Pwned</a>
          <span class="text-gray-500"> — Check if your email/password appeared in data breaches.</span>
        </div>
        <div class="border-l border-gray-700 pl-4">
          <a href="https://tosdr.org" target="_blank" rel="noopener" class="text-cyan-400 hover:text-green-400">Terms of Service; Didn't Read</a>
          <span class="text-gray-500"> — Human-readable ratings of website terms of service and privacy policies.</span>
        </div>
      </div>
      <div class="text-amber-400">└──────────────────────────────────────────────────────────┘</div>
    </section>

    <!-- Footer note -->
    <div class="text-center text-gray-600 text-xs mt-8 mb-4">
      <p>This terminal has no affiliate relationships with any listed destination.</p>
      <p>All links are recommendations based on research and community consensus.</p>
      <p class="text-gray-700 mt-2">Last updated: March 2026 │ Suggest a destination: <a href="https://github.com/vespillo-tech/privacyterminal" class="text-cyan-400 hover:text-green-400">GitHub</a></p>
    </div>

  </div>
</BaseLayout>
