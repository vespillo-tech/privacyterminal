---
// AchievementToast.astro -- Achievement unlock popup notification
---

<!-- Achievement Toast Container -->
<div id="pt-toast-container" class="fixed bottom-10 right-4 z-[300] flex flex-col gap-2 pointer-events-none" aria-live="polite"></div>

<style>
  .pt-toast {
    pointer-events: auto;
    border: 1px solid #00ff41;
    background: #0a0a0a;
    box-shadow: 0 0 16px rgba(0,255,65,0.25), 0 0 4px rgba(0,255,65,0.15);
    font-family: "JetBrains Mono", monospace;
    min-width: 260px;
    max-width: 320px;
    transform: translateX(110%);
    opacity: 0;
    transition: transform 0.3s cubic-bezier(0.16,1,0.3,1), opacity 0.3s ease;
  }
  .pt-toast.pt-toast-show {
    transform: translateX(0);
    opacity: 1;
  }
  .pt-toast.pt-toast-hide {
    transform: translateX(110%);
    opacity: 0;
  }
</style>

<script>
import type { AchievementDef } from '../scripts/privacy-score';

const container = document.getElementById('pt-toast-container')!;

function showToast(ach: AchievementDef): void {
  const toast = document.createElement('div');
  toast.className = 'pt-toast relative';

  toast.innerHTML =
    '<div class="px-3 py-1 border-b border-terminal-border">' +
    '  <span class="text-terminal-green text-[10px] font-bold">├ ACHIEVEMENT UNLOCKED ┤</span>' +
    '</div>' +
    '<div class="px-3 py-2">' +
    '  <div class="flex items-start justify-between gap-2">' +
    '    <div>' +
    '      <div class="text-white text-xs font-bold">' + ach.icon + ' ' + ach.name + '</div>' +
    '      <div class="text-terminal-muted text-[10px] mt-0.5">' + ach.description + '</div>' +
    '    </div>' +
    '    <div class="text-terminal-green text-xs font-bold whitespace-nowrap">+' + String(ach.points) + ' pts</div>' +
    '  </div>' +
    '</div>';

  container.appendChild(toast);

  // Trigger slide-in
  requestAnimationFrame(() => {
    requestAnimationFrame(() => toast.classList.add('pt-toast-show'));
  });

  // Auto-dismiss after 4s
  setTimeout(() => {
    toast.classList.remove('pt-toast-show');
    toast.classList.add('pt-toast-hide');
    toast.addEventListener('transitionend', () => toast.remove(), { once: true });
  }, 4000);
}

window.addEventListener('pt:achievement', (e: Event) => {
  const detail = (e as CustomEvent<AchievementDef>).detail;
  if (detail) showToast(detail);
});
</script>
