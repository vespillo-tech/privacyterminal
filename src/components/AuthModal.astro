---
import { getEntry } from 'astro:content';

const authEntry = await getEntry('site', 'auth-copy');
const ac = authEntry?.data as {
  register: {
    title: string;
    subtitle_lines: string[];
    promise: string;
    create_button: string;
    switch_to_login: string;
  };
  recovery: {
    title: string;
    warning: string;
    storage_note: string;
    copy_button: string;
    saved_button: string;
  };
  login: {
    title: string;
    input_placeholder: string;
    prompt: string;
    submit_button: string;
    switch_to_register: string;
    error_invalid: string;
    error_empty: string;
  };
  loading_text: string;
};
---
<!-- Auth Modal Overlay -->
<div id="pt-auth-modal" class="fixed inset-0 z-[200] flex items-center justify-center" style="display:none!important" aria-modal="true" role="dialog">
  <!-- Backdrop -->
  <div id="pt-auth-backdrop" class="absolute inset-0 bg-black/80"></div>

  <!-- Modal Box -->
  <div class="relative tui-box max-w-sm w-full mx-4 bg-terminal-bg" style="box-shadow:0 0 24px rgba(0,255,65,0.15)">
    <!-- Close button -->
    <button id="pt-auth-close" class="absolute top-2 right-3 text-terminal-muted hover:text-terminal-red text-xs" aria-label="Close">[x] close</button>

    <!-- REGISTER VIEW -->
    <div id="pt-view-register" class="p-5">
      <span class="tui-box-title text-terminal-green">├ {ac.register.title} ┤</span>
      <div class="mt-3 text-xs text-terminal-muted space-y-1 leading-relaxed">
        {ac.register.subtitle_lines.map((line: string) => <p>{line}</p>)}
      </div>
      <div class="mt-3 text-center text-terminal-green text-xs font-bold">
        {ac.register.promise}
      </div>
      <div class="mt-4">
        <button id="pt-btn-create" class="btn-terminal w-full text-xs py-2">
          {ac.register.create_button}
        </button>
      </div>
      <div class="mt-2 text-center">
        <button id="pt-switch-to-login" class="text-terminal-cyan hover:text-terminal-green text-xs transition-colors">
          {ac.register.switch_to_login}
        </button>
      </div>
    </div>

    <!-- RECOVERY CODE VIEW -->
    <div id="pt-view-code" class="p-5" style="display:none">
      <span class="tui-box-title text-terminal-green">├ {ac.recovery.title} ┤</span>
      <div class="mt-3">
        <div class="border border-terminal-green p-3 text-center" style="box-shadow:0 0 8px rgba(0,255,65,0.2)">
          <div id="pt-recovery-display" class="text-terminal-green font-bold text-sm tracking-widest"></div>
        </div>
      </div>
      <div class="mt-3 text-xs text-terminal-muted space-y-1 leading-relaxed">
        <p class="text-terminal-amber">{ac.recovery.warning}</p>
        <p>{ac.recovery.storage_note}</p>
      </div>
      <div class="mt-4 grid grid-cols-2 gap-2">
        <button id="pt-btn-copy" class="btn-terminal text-xs py-2">{ac.recovery.copy_button}</button>
        <button id="pt-btn-saved" class="btn-terminal text-xs py-2">{ac.recovery.saved_button}</button>
      </div>
    </div>

    <!-- LOGIN VIEW -->
    <div id="pt-view-login" class="p-5" style="display:none">
      <span class="tui-box-title text-terminal-cyan">├ {ac.login.title} ┤</span>
      <div class="mt-3 text-xs text-terminal-muted">{ac.login.prompt}</div>
      <div class="mt-2">
        <input
          id="pt-code-input"
          type="text"
          placeholder={ac.login.input_placeholder}
          autocomplete="off"
          spellcheck="false"
          class="w-full bg-transparent border border-terminal-border text-terminal-green text-xs font-mono px-3 py-2 focus:border-terminal-cyan focus:outline-none uppercase tracking-widest" data-error-empty={ac.login.error_empty} data-error-invalid={ac.login.error_invalid}
        />
      </div>
      <div id="pt-login-error" class="mt-1 text-terminal-red text-xs" style="display:none"></div>
      <div class="mt-3">
        <button id="pt-btn-login" class="btn-terminal w-full text-xs py-2">{ac.login.submit_button}</button>
      </div>
      <div class="mt-2 text-center">
        <button id="pt-switch-to-register" class="text-terminal-cyan hover:text-terminal-green text-xs transition-colors">
          {ac.login.switch_to_register}
        </button>
      </div>
    </div>

    <!-- PASSKEY REGISTER VIEW -->
    <div id="pt-view-passkey-register" class="p-5" style="display:none">
      <span class="tui-box-title text-terminal-green">├ REGISTER PASSKEY ┤</span>
      <div class="mt-3 text-xs text-terminal-muted space-y-1 leading-relaxed">
        <p>Use your fingerprint, face, or security key for instant sign-in.</p>
        <p>No codes to remember.</p>
      </div>
      <div class="mt-4">
        <button id="pt-btn-passkey-register" class="btn-terminal w-full text-xs py-2">
          [+] Register Passkey
        </button>
      </div>
      <div id="pt-passkey-register-error" class="mt-1 text-terminal-red text-xs" style="display:none"></div>
      <div id="pt-passkey-register-success" class="mt-2 text-terminal-green text-xs" style="display:none">
        ✓ Passkey registered successfully!
      </div>
      <div class="mt-2 text-center">
        <button id="pt-passkey-back" class="text-terminal-muted hover:text-terminal-cyan text-xs transition-colors">
          [← back]
        </button>
      </div>
    </div>

    <!-- PASSKEY LOGIN VIEW -->
    <div id="pt-view-passkey-login" class="p-5" style="display:none">
      <span class="tui-box-title text-terminal-cyan">├ SIGN IN WITH PASSKEY ┤</span>
      <div class="mt-3 text-xs text-terminal-muted">
        Touch your fingerprint sensor or security key.
      </div>
      <div class="mt-4">
        <button id="pt-btn-passkey-login" class="btn-terminal w-full text-xs py-2">
          [>] Use Passkey
        </button>
      </div>
      <div id="pt-passkey-login-error" class="mt-1 text-terminal-red text-xs" style="display:none"></div>
      <div class="mt-2 text-center">
        <button id="pt-switch-to-code-login" class="text-terminal-cyan hover:text-terminal-green text-xs transition-colors">
          Prefer recovery code? [Use Code →]
        </button>
      </div>
    </div>

    <!-- LOADING STATE -->
    <div id="pt-view-loading" class="p-5 text-center" style="display:none">
      <div class="text-terminal-green text-xs animate-pulse">{ac.loading_text}<span class="cursor-blink"></span></div>
    </div>
  </div>
</div>
<script>
import { register, login, isLoggedIn } from '../scripts/privacy-score';

const modal    = document.getElementById('pt-auth-modal')!;
const backdrop = document.getElementById('pt-auth-backdrop')!;
const close    = document.getElementById('pt-auth-close')!;

const views = {
  register: document.getElementById('pt-view-register')!,
  code:     document.getElementById('pt-view-code')!,
  login:    document.getElementById('pt-view-login')!,
  loading:  document.getElementById('pt-view-loading')!,
};

function showView(name: keyof typeof views): void {
  Object.values(views).forEach(v => (v.style.display = 'none'));
  views[name].style.display = 'block';
}

function openModal(view: keyof typeof views = 'register'): void {
  modal.style.removeProperty('display');
  modal.style.display = 'flex';
  showView(view);
  document.body.style.overflow = 'hidden';
}

function closeModal(): void {
  modal.style.display = 'none';
  document.body.style.overflow = '';
}

window.addEventListener('pt:open-auth', () => openModal('register'));
window.addEventListener('pt:open-login', () => openModal('login'));

close.addEventListener('click', closeModal);
backdrop.addEventListener('click', closeModal);
document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') closeModal(); });

document.getElementById('pt-switch-to-login')!.addEventListener('click', () => showView('login'));
document.getElementById('pt-switch-to-register')!.addEventListener('click', () => showView('register'));

document.getElementById('pt-btn-create')!.addEventListener('click', async () => {
  showView('loading');
  try {
    const result = await register();
    const display = document.getElementById('pt-recovery-display')!;
    display.textContent = result.recovery_code;
    showView('code');
  } catch (err) {
    showView('register');
    console.error('Registration failed:', err);
  }
});

document.getElementById('pt-btn-copy')!.addEventListener('click', async () => {
  const code = document.getElementById('pt-recovery-display')!.textContent ?? '';
  try {
    await navigator.clipboard.writeText(code);
    const btn = document.getElementById('pt-btn-copy')!;
    btn.textContent = '[v] Copied!';
    setTimeout(() => { btn.textContent = '[=] Copy Code'; }, 2000);
  } catch { /* ignore */ }
});

document.getElementById('pt-btn-saved')!.addEventListener('click', closeModal);

document.getElementById('pt-btn-login')!.addEventListener('click', async () => {
  const input  = document.getElementById('pt-code-input') as HTMLInputElement;
  const errEl  = document.getElementById('pt-login-error')!;
  const code   = input.value.trim();
  // Read error messages from DOM data attributes set at build time
  const emptyMsg   = input.dataset.errorEmpty   ?? 'Please enter your recovery code.';
  const invalidMsg = input.dataset.errorInvalid  ?? 'Invalid recovery code. Check your spelling and try again.';
  if (!code) {
    errEl.textContent = emptyMsg;
    errEl.style.display = 'block';
    return;
  }
  errEl.style.display = 'none';
  showView('loading');
  const ok = await login(code);
  if (ok) {
    closeModal();
    input.value = '';
  } else {
    showView('login');
    errEl.textContent = invalidMsg;
    errEl.style.display = 'block';
  }
});

document.getElementById('pt-code-input')!.addEventListener('keydown', (e: KeyboardEvent) => {
  if (e.key === 'Enter') document.getElementById('pt-btn-login')!.click();
});

if (!isLoggedIn()) {
  const stored = localStorage.getItem('pt_progress');
  if (stored) {
    try {
      const p = JSON.parse(stored);
      if (p.score >= 50) {
        setTimeout(() => { if (!isLoggedIn()) openModal('register'); }, 30000);
      }
    } catch { /* ignore */ }
  }
}

// ── Passkey (WebAuthn) Support ──────────────────────────────────
const PASSKEY_CRED_KEY = 'pt_passkey_cred';
const PASSKEY_SESSION_KEY = 'pt_passkey_session';

function supportsPasskeys() {
  return !!(window.PublicKeyCredential && navigator.credentials && navigator.credentials.create);
}

function getStoredCredId() {
  try { return localStorage.getItem(PASSKEY_CRED_KEY); } catch { return null; }
}

// Show passkey buttons if supported
if (supportsPasskeys()) {
  var passkeyFromLogin = document.getElementById('pt-switch-to-passkey-from-login');
  if (passkeyFromLogin && getStoredCredId()) passkeyFromLogin.style.display = 'block';

  // Show passkey offer after registration
  var passkeyOffer = document.getElementById('pt-passkey-offer');
  if (passkeyOffer) {
    var origSaved = document.getElementById('pt-btn-saved');
    if (origSaved) {
      var origClick = origSaved.onclick;
      origSaved.addEventListener('click', function() {
        if (passkeyOffer) passkeyOffer.style.display = 'block';
      });
    }
  }
}

// Passkey views
var passkeyViews = {
  'pt-switch-to-passkey-from-login': 'passkey-login',
  'pt-passkey-back': 'register',
  'pt-switch-to-code-login': 'login',
};

Object.keys(passkeyViews).forEach(function(btnId) {
  var btn = document.getElementById(btnId);
  if (btn) {
    btn.addEventListener('click', function() {
      showView(passkeyViews[btnId].replace('passkey-', 'passkey_'));
    });
  }
});

// Map view names to elements
var pkRegView = document.getElementById('pt-view-passkey-register');
var pkLoginView = document.getElementById('pt-view-passkey-login');
if (pkRegView) views['passkey_register'] = pkRegView;
if (pkLoginView) views['passkey_login'] = pkLoginView;

// Navigate passkey buttons
var switchToPasskeyLogin = document.getElementById('pt-switch-to-passkey-from-login');
if (switchToPasskeyLogin) switchToPasskeyLogin.addEventListener('click', function() { showView('passkey_login'); });
var passkeyBackBtn = document.getElementById('pt-passkey-back');
if (passkeyBackBtn) passkeyBackBtn.addEventListener('click', function() { showView('register'); });
var switchToCodeLogin = document.getElementById('pt-switch-to-code-login');
if (switchToCodeLogin) switchToCodeLogin.addEventListener('click', function() { showView('login'); });

// Passkey Registration
var btnPasskeyRegister = document.getElementById('pt-btn-passkey-register');
if (btnPasskeyRegister) {
  btnPasskeyRegister.addEventListener('click', async function() {
    var errEl = document.getElementById('pt-passkey-register-error');
    var successEl = document.getElementById('pt-passkey-register-success');
    if (errEl) errEl.style.display = 'none';
    if (successEl) successEl.style.display = 'none';

    if (!supportsPasskeys()) {
      if (errEl) { errEl.textContent = "Your browser doesn't support passkeys."; errEl.style.display = 'block'; }
      return;
    }

    try {
      var userId = new Uint8Array(16);
      crypto.getRandomValues(userId);
      var challenge = new Uint8Array(32);
      crypto.getRandomValues(challenge);

      var credential = await navigator.credentials.create({
        publicKey: {
          challenge: challenge,
          rp: { name: 'Privacy Terminal', id: window.location.hostname },
          user: {
            id: userId,
            name: 'privacy-terminal-user',
            displayName: 'Privacy Terminal User'
          },
          pubKeyCredParams: [
            { alg: -7, type: 'public-key' },
            { alg: -257, type: 'public-key' }
          ],
          authenticatorSelection: {
            authenticatorAttachment: 'platform',
            userVerification: 'preferred',
            residentKey: 'preferred'
          },
          timeout: 60000
        }
      });

      if (credential && credential.rawId) {
        var credId = btoa(String.fromCharCode.apply(null, new Uint8Array(credential.rawId)));
        localStorage.setItem(PASSKEY_CRED_KEY, credId);
        // Store current session token association
        var token = localStorage.getItem('pt_session');
        if (token) {
          localStorage.setItem(PASSKEY_SESSION_KEY, token);
        }
        if (successEl) successEl.style.display = 'block';
        btnPasskeyRegister.textContent = '[v] Passkey Registered';
        btnPasskeyRegister.disabled = true;
      }
    } catch (err) {
      if (errEl) {
        errEl.textContent = 'Passkey registration failed: ' + (err.message || 'Unknown error');
        errEl.style.display = 'block';
      }
    }
  });
}

// Offer passkey registration after recovery code creation
var btnOfferPasskey = document.getElementById('pt-btn-offer-passkey');
if (btnOfferPasskey) {
  btnOfferPasskey.addEventListener('click', function() {
    showView('passkey_register');
  });
}

// Passkey Login
var btnPasskeyLogin = document.getElementById('pt-btn-passkey-login');
if (btnPasskeyLogin) {
  btnPasskeyLogin.addEventListener('click', async function() {
    var errEl = document.getElementById('pt-passkey-login-error');
    if (errEl) errEl.style.display = 'none';

    if (!supportsPasskeys()) {
      if (errEl) { errEl.textContent = "Your browser doesn't support passkeys."; errEl.style.display = 'block'; }
      return;
    }

    var storedCredId = getStoredCredId();
    if (!storedCredId) {
      if (errEl) { errEl.textContent = 'No passkey found. Register one first.'; errEl.style.display = 'block'; }
      return;
    }

    try {
      var challenge = new Uint8Array(32);
      crypto.getRandomValues(challenge);
      var rawId = Uint8Array.from(atob(storedCredId), function(c) { return c.charCodeAt(0); });

      var assertion = await navigator.credentials.get({
        publicKey: {
          challenge: challenge,
          allowCredentials: [{
            id: rawId,
            type: 'public-key',
            transports: ['internal']
          }],
          userVerification: 'preferred',
          timeout: 60000
        }
      });

      if (assertion) {
        // Restore session from stored association
        var savedToken = localStorage.getItem(PASSKEY_SESSION_KEY);
        if (savedToken) {
          localStorage.setItem('pt_session', savedToken);
          closeModal();
          window.dispatchEvent(new CustomEvent('pt:progress'));
          window.location.reload();
        } else {
          if (errEl) { errEl.textContent = 'Passkey verified but no session found. Use recovery code instead.'; errEl.style.display = 'block'; }
        }
      }
    } catch (err) {
      if (errEl) {
        errEl.textContent = 'Passkey authentication failed. Try again or use your recovery code.';
        errEl.style.display = 'block';
      }
    }
  });
}

</script>
